<% note = local_assigns.fetch(:note) %>
<% highlight_ids = local_assigns.fetch(:highlight_ids, []) %>
<% existing = note.persisted? %>
<%
  # eyebrow_classes: section-eyebrow treatment (form section legends,
  # share-target labels). mono caps for the deliberate form-control
  # rhythm — short label strings ("Visibility", "Share with users",
  # "Share with groups") with no proper-noun content. Radio-button
  # text labels ("Private", "Friends", "Public") stay sans body via
  # the fieldset's font-ui text-sm — only the eyebrow goes mono.
  eyebrow_classes = "block font-ui text-xs font-medium uppercase tracking-widest text-surface-500 dark:text-surface-400"
  input_classes   = "w-full rounded-md border border-surface-300 bg-surface-50 px-3 py-2 font-ui text-sm text-surface-900 transition-colors placeholder:text-surface-500 focus:border-accent-700 focus:outline-none focus:ring-2 focus:ring-accent-700/20 dark:border-surface-700 dark:bg-surface-900 dark:text-surface-100 dark:focus:border-accent-400 dark:focus:ring-accent-400/20"
  submit_classes  = "rounded-full bg-accent-700 px-7 py-2.5 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800 dark:bg-accent-400 dark:text-surface-950 dark:hover:bg-accent-300"
  danger_classes  = "rounded-md border border-red-500/40 bg-transparent px-3 py-1.5 font-ui text-xs font-medium text-red-700 transition-colors hover:bg-red-500 hover:text-surface-50 dark:border-red-400/40 dark:text-red-300 dark:hover:bg-red-500 dark:hover:text-surface-50"
%>

<%= turbo_frame_tag "note_panel" do %>
  <section class="note-panel"
           data-controller="note-panel"
           data-note-panel-open-value="true">
    <% citation_osis = local_assigns[:citation_osis] %>
    <header class="flex items-start justify-between border-b border-surface-200 pb-3 dark:border-surface-800">
      <div>
        <h2 class="font-ui text-lg font-semibold tracking-tight text-surface-900 dark:text-surface-50">
          <%= highlight_ids.any? || existing ? "Note" : "New note" %>
        </h2>
        <% if citation_osis.present? %>
          <p class="mt-0.5 font-ui text-xs text-surface-500 dark:text-surface-400">
            <%= osis_citation(citation_osis) %>
          </p>
        <% end %>
      </div>
      <button type="button"
              data-action="note-panel#close"
              aria-label="Close"
              class="rounded-md p-1 text-xl text-surface-600 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:text-surface-400 dark:hover:bg-surface-800 dark:hover:text-surface-100">
        &times;
      </button>
    </header>

    <%= form_with model: note,
                  url: existing ? note_path(note) : notes_path,
                  method: existing ? :patch : :post,
                  data: { turbo_frame: "note_panel", action: "keydown->note-panel#keydown" },
                  class: "mt-4 space-y-4" do |f| %>

      <% highlight_ids.each do |id| %>
        <%= hidden_field_tag "note[highlight_ids][]", id %>
      <% end %>

      <div>
        <%= f.rich_text_area :body, autofocus: true %>
      </div>

      <div data-note-panel-target="shareSection" data-visibility-dependent="shared_users">
        <label class="mb-1.5 <%= eyebrow_classes %>">
          <%= t("notes.share_with_users") %>
        </label>
        <%# Friend picker (Sprint R6): mutual follows as checkboxes —
            the primary path. The checked ids ride the existing
            note[user_ids][] param into sync_shares. %>
        <% friends = current_user.friends.order(:display_name, :email) %>
        <% shared_user_ids = note.shared_users.map(&:id) %>
        <% if friends.any? %>
          <div class="font-ui text-sm text-surface-700 dark:text-surface-300">
            <% friends.each do |friend| %>
              <label class="touch-target-row flex cursor-pointer items-center gap-2 rounded-md px-1 py-2 -mx-1 hover:bg-surface-100 dark:hover:bg-surface-800">
                <%= check_box_tag "note[user_ids][]", friend.id, shared_user_ids.include?(friend.id), id: "note_user_ids_#{friend.id}", class: "h-4 w-4 accent-accent-700 dark:accent-accent-400" %>
                <%= friend.author_name %>
              </label>
            <% end %>
          </div>
          <p class="mt-2 mb-1.5 font-ui text-xs text-surface-500 dark:text-surface-400">
            <%= t("notes.or_invite_by_email") %>
          </p>
        <% end %>
        <input type="text"
               inputmode="email"
               name="note[user_emails]"
               value="<%= note.shared_users.reject { |u| friends.include?(u) }.map(&:email).join(", ") %>"
               placeholder="<%= t("notes.emails_placeholder") %>"
               autocomplete="off"
               class="<%= input_classes %>">
      </div>

      <div data-note-panel-target="shareSection" data-visibility-dependent="shared_groups">
        <label class="mb-1.5 <%= eyebrow_classes %>">
          <%= t("notes.share_with_groups") %>
        </label>
        <div class="font-ui text-sm text-surface-700 dark:text-surface-300">
          <% current_user.groups.distinct.order(:name).each do |g| %>
            <label class="touch-target-row flex cursor-pointer items-center gap-2 rounded-md px-1 py-2 -mx-1 hover:bg-surface-100 dark:hover:bg-surface-800">
              <%= check_box_tag "note[group_ids][]", g.id, note.shared_groups.include?(g), class: "h-4 w-4 accent-accent-700 dark:accent-accent-400" %>
              <%= g.name %>
            </label>
          <% end %>
        </div>
      </div>

      <%# Inline warning replaces window.confirm() for the public option.
          Shown by confirmPublic(), hidden by cancelPublic/acceptPublic.
          Lives in the form body (not inside the Post-to menu) so it
          stays visible after the menu closes on selection. %>
      <div data-note-panel-target="publicWarning"
           hidden
           class="rounded-md border border-amber-200 bg-amber-50 p-3 dark:border-amber-800 dark:bg-amber-950/30">
        <p class="font-ui text-sm text-amber-800 dark:text-amber-200">
          <%= t("notes.public_warning") %>
        </p>
        <div class="mt-2 flex gap-2">
          <button type="button"
                  data-action="note-panel#cancelPublic"
                  class="rounded-md border border-surface-300 bg-surface-50 px-3 py-1.5 font-ui text-xs font-medium text-surface-700 transition-colors hover:bg-surface-100 dark:border-surface-700 dark:bg-surface-900 dark:text-surface-300 dark:hover:bg-surface-800">
            <%= t("notes.cancel_public") %>
          </button>
          <button type="button"
                  data-action="note-panel#acceptPublic"
                  class="rounded-md bg-amber-700 px-3 py-1.5 font-ui text-xs font-medium text-white transition-colors hover:bg-amber-800 dark:bg-amber-600 dark:hover:bg-amber-500">
            <%= t("notes.confirm_public") %>
          </button>
        </div>
      </div>

      <div class="flex flex-wrap items-center justify-between gap-3 pt-2">
        <%# Hypothes.is pattern: visibility is a property of the act of
            posting, so it lives on the footer's Post-to control, not in
            a form section. A native <details> drops up a menu of the
            four visibility radios — no JS needed for open/close; the
            note-panel controller closes it after a pick and keeps the
            summary label in sync. public_note still routes through
            confirmPublic's inline warning above. %>
        <details class="relative" data-note-panel-target="postMenu">
          <summary class="flex cursor-pointer list-none items-center gap-1.5 rounded-full border border-surface-300 px-4 py-2 font-ui text-sm text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:border-surface-700 dark:text-surface-300 dark:hover:bg-surface-800 dark:hover:text-surface-50 [&::-webkit-details-marker]:hidden">
            <span class="text-surface-500 dark:text-surface-400"><%= t("notes.post_to") %></span>
            <span class="font-medium" data-note-panel-target="postLabel"><%= t("notes.visibility.#{note.visibility || 'private_note'}") %></span>
            <span aria-hidden="true" class="text-xs text-surface-500 dark:text-surface-400">&#9662;</span>
          </summary>
          <div class="absolute bottom-full left-0 z-10 mb-2 w-60 rounded-xl border border-surface-200 bg-surface-50 p-1 font-ui text-sm text-surface-700 shadow-lg dark:border-surface-800 dark:bg-surface-900 dark:text-surface-300">
            <% NotesController::ACTIVE_VISIBILITIES.each do |v| %>
              <label class="touch-target-row flex cursor-pointer items-center gap-2 rounded-lg px-3 py-2 hover:bg-surface-100 dark:hover:bg-surface-800">
                <%= f.radio_button :visibility, v,
                                   checked: (note.visibility || "private_note") == v,
                                   data: { label: t("notes.visibility.#{v}") }.merge(v == "public_note" ? { action: "change->note-panel#confirmPublic" } : {}),
                                   class: "h-4 w-4 accent-accent-700 dark:accent-accent-400" %>
                <%= t("notes.visibility.#{v}", default: v.humanize) %>
              </label>
            <% end %>
          </div>
        </details>

        <div class="flex items-center gap-3">
          <% if existing %>
            <%= button_to t("notes.delete"),
                          note_path(note),
                          method: :delete,
                          form_class: "inline",
                          data: { turbo_confirm: t("notes.confirm_delete"), turbo_frame: "note_panel" },
                          class: danger_classes %>
          <% end %>
          <%= f.submit t("notes.save"), class: submit_classes %>
        </div>
      </div>
    <% end %>
  </section>
<% end %>
