<!DOCTYPE html>
<%# resolved_theme is "light"/"dark" only when the signed-in user pinned
    it; otherwise the Stimulus controller decides on connect and we leave
    data-theme unset. That avoids a flash of the wrong palette for users
    who've saved a preference. %>
<html lang="<%= I18n.locale %>"<%= " data-theme=\"#{resolved_theme}\"".html_safe if resolved_theme %> data-controller="theme">
  <head>
    <%# No-flash theme: runs synchronously before any stylesheet is applied.
        Sets data-theme on <html> so the first CSS evaluation already targets
        the correct palette — no 150ms transition fires on initial load and
        axe always sees a stable state. Server-set data-theme (pinned user
        preference) takes precedence; script exits early if it is present. %>
    <script>
      (function(){
        var el = document.documentElement;
        if (el.dataset.theme === "light" || el.dataset.theme === "dark") return;
        var stored = localStorage.getItem("open-bible:theme");
        if (stored === "dark" || stored === "light") { el.dataset.theme = stored; return; }
        el.dataset.theme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
      })();
    </script>
    <% page_title = content_for?(:title) ? "#{content_for(:title)} · #{t("app.name")}" : t("app.name") %>
    <% page_description = content_for?(:meta_description) ? content_for(:meta_description) : t("app.meta_description") %>
    <% canonical_url = request.original_url.split("?").first %>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t("app.name") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= page_description %>">

    <%# Open Graph + Twitter card meta — used by Facebook, LinkedIn,
        Slack, iMessage, Twitter, etc. when a URL is shared. og:image
        falls back to /icon.png (the 512x512 brand glyph) since we
        don't ship a per-page social-card image yet. twitter:card =
        "summary" renders the small square card variant which fits
        the icon's aspect ratio; upgrade to "summary_large_image"
        once a 1200×630 social card asset is generated. %>
    <meta property="og:site_name" content="<%= t("app.name") %>">
    <meta property="og:title" content="<%= page_title %>">
    <meta property="og:description" content="<%= page_description %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= canonical_url %>">
    <meta property="og:image" content="<%= request.base_url %>/icon.png">
    <meta property="og:locale" content="<%= I18n.locale == :es ? "es_ES" : "en_US" %>">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= page_title %>">
    <meta name="twitter:description" content="<%= page_description %>">
    <meta name="twitter:image" content="<%= request.base_url %>/icon.png">

    <link rel="canonical" href="<%= canonical_url %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Self-hosted fonts live in /public/fonts and are loaded via
        @font-face rules in application.css. No Google Fonts or other
        third-party hosts — see CLAUDE.md. %>
    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/InstrumentSerif-Regular.woff2" as="font" type="font/woff2" crossorigin>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:rounded focus:bg-surface-900 focus:px-3 focus:py-1 focus:text-surface-50 font-ui">
      <%= t("layout.skip_to_content") %>
    </a>

    <header class="site-header" data-controller="site-header">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <%= link_to root_path, class: "inline-flex items-center gap-2.5 font-ui text-lg font-semibold tracking-tight text-surface-900 transition-colors hover:text-accent-700 dark:text-surface-50 dark:hover:text-accent-400" do %>
          <span class="wordmark-mark" aria-hidden="true"></span>
          <%= t("app.name") %>
        <% end %>

        <nav class="flex items-center gap-1 font-ui text-sm" aria-label="<%= t("layout.account") %>">
          <% if user_signed_in? %>
            <%# Notes and Groups are the social backbone — surface them
                in the top nav so signed-in users always have one tap to
                their content. Hidden below sm to keep the mobile rail tight. %>
            <%= link_to t("layout.my_notes_link"), notes_path,
                        class: "hidden sm:inline-block rounded-md px-3 py-1.5 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:hover:bg-surface-800 dark:hover:text-surface-50 #{nav_active?(notes_path) ? 'text-accent-700 underline underline-offset-4 decoration-accent-700/40 dark:text-accent-400 dark:decoration-accent-400/40' : 'text-surface-700 dark:text-surface-300'}" %>
            <%= link_to t("layout.my_groups_link"), groups_path,
                        class: "hidden sm:inline-block rounded-md px-3 py-1.5 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:hover:bg-surface-800 dark:hover:text-surface-50 #{nav_active?(groups_path) ? 'text-accent-700 underline underline-offset-4 decoration-accent-700/40 dark:text-accent-400 dark:decoration-accent-400/40' : 'text-surface-700 dark:text-surface-300'}" %>
          <% end %>

          <%# Active-state on the search link uses mint text instead of
              the idle surface-tones — the "you are here" cue when the
              current route is /search. Hover behavior unchanged in
              both states. %>
          <%= link_to search_path, class: "rounded-md px-3 py-1.5 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:hover:bg-surface-800 dark:hover:text-surface-50 #{nav_active?(search_path) ? 'text-accent-700 underline underline-offset-4 decoration-accent-700/40 dark:text-accent-400 dark:decoration-accent-400/40' : 'text-surface-700 dark:text-surface-300'}" do %>
            <%= t("search.submit") %>
          <% end %>

          <div data-controller="user-menu" class="relative">
            <button type="button"
                    data-user-menu-target="trigger"
                    data-action="user-menu#toggle"
                    aria-expanded="false"
                    aria-haspopup="true"
                    aria-label="<%= t("layout.open_menu") %>"
                    class="flex items-center gap-1.5 rounded-md px-3 py-1.5 text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:text-surface-300 dark:hover:bg-surface-800 dark:hover:text-surface-50">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                <path fill-rule="evenodd" d="M18 5.25a.75.75 0 0 1-.75.75H2.75a.75.75 0 0 1 0-1.5h14.5a.75.75 0 0 1 .75.75ZM18 10a.75.75 0 0 1-.75.75H2.75a.75.75 0 0 1 0-1.5h14.5A.75.75 0 0 1 18 10Zm0 4.75a.75.75 0 0 1-.75.75H2.75a.75.75 0 0 1 0-1.5h14.5a.75.75 0 0 1 .75.75Z" clip-rule="evenodd" />
              </svg>
              <span class="hidden sm:inline"><%= t("layout.account") %></span>
            </button>

            <div data-user-menu-target="menu"
                 hidden
                 role="menu"
                 aria-label="<%= t("layout.account") %>"
                 class="account-sheet">

              <%# Account-menu items share a single base class plus an
                  idle/active swap. Active uses mint text on the same
                  tinted bg the hover state already paints, so the
                  current route reads as "you are here" without a new
                  visual. %>
              <% menu_item_base   = "block px-4 py-2 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:hover:bg-surface-800 dark:hover:text-surface-50" %>
              <% menu_item_idle   = "text-surface-700 dark:text-surface-300" %>
              <% menu_item_active = "bg-surface-100 text-accent-700 dark:bg-surface-800 dark:text-accent-400" %>

              <% if user_signed_in? %>
                <div class="px-4 py-2 text-xs uppercase tracking-wide text-surface-500 dark:text-surface-400">
                  <%= current_user.email %>
                </div>
                <div class="my-1 border-t border-surface-200 dark:border-surface-800" role="separator"></div>
                <% if current_user.admin? %>
                  <%# Admin link covers all /admin/* pages, not just /admin/notes,
                      so the "you are here" cue stays correct on subroutes like
                      /admin/flags or /admin/bitcoin_addresses. %>
                  <%= link_to admin_notes_path, role: "menuitem", class: "#{menu_item_base} #{request.path.start_with?("/admin") ? menu_item_active : menu_item_idle}" do %><%= t("admin.title") %><% end %>
                <% end %>
                <%= link_to settings_path, role: "menuitem", class: "#{menu_item_base} #{nav_active?(settings_path) ? menu_item_active : menu_item_idle}" do %><%= t("auth.settings") %><% end %>
              <% else %>
                <%#  Sign-up intentionally omitted — Devise's sign-in form
                     renders a "Sign up" link underneath via the shared
                     _links partial, which is one click away. Matches the
                     Grammarly/Notion/Linear/Stripe navbar pattern. %>
                <%= link_to new_user_session_path, role: "menuitem", class: "#{menu_item_base} #{nav_active?(new_user_session_path) ? menu_item_active : menu_item_idle}" do %><%= t("auth.sign_in") %><% end %>
              <% end %>

              <div class="my-1 border-t border-surface-200 dark:border-surface-800" role="separator"></div>

              <button type="button"
                      data-action="theme#toggle"
                      role="menuitem"
                      aria-label="<%= t("layout.theme_switch") %>"
                      class="flex w-full items-center gap-2 px-4 py-2 text-left text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:text-surface-300 dark:hover:bg-surface-800 dark:hover:text-surface-50">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="theme-icon-sun h-4 w-4" aria-hidden="true">
                  <path d="M10 2a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0v-1.5A.75.75 0 0 1 10 2ZM10 15a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0v-1.5A.75.75 0 0 1 10 15ZM10 7a3 3 0 1 0 0 6 3 3 0 0 0 0-6ZM15.657 5.404a.75.75 0 0 0-1.06-1.06l-1.061 1.06a.75.75 0 1 0 1.06 1.06l1.06-1.06ZM6.464 14.596a.75.75 0 0 0-1.06-1.06l-1.06 1.06a.75.75 0 0 0 1.06 1.06l1.06-1.06ZM18 10a.75.75 0 0 1-.75.75h-1.5a.75.75 0 0 1 0-1.5h1.5A.75.75 0 0 1 18 10ZM5 10a.75.75 0 0 1-.75.75h-1.5a.75.75 0 0 1 0-1.5h1.5A.75.75 0 0 1 5 10ZM14.596 15.657a.75.75 0 0 0 1.06-1.06l-1.06-1.061a.75.75 0 1 0-1.06 1.06l1.06 1.06ZM5.404 6.464a.75.75 0 0 0 1.06-1.06l-1.06-1.06a.75.75 0 1 0-1.061 1.06l1.06 1.06Z" />
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="theme-icon-moon h-4 w-4" aria-hidden="true">
                  <path fill-rule="evenodd" d="M7.455 2.004a.75.75 0 0 1 .26.77 7 7 0 0 0 9.958 7.967.75.75 0 0 1 1.067.853A8.5 8.5 0 1 1 6.647 1.921a.75.75 0 0 1 .808.083Z" clip-rule="evenodd" />
                </svg>
                <span data-theme-target="label"
                      data-label-light="<%= t("layout.theme_light") %>"
                      data-label-dark="<%= t("layout.theme_dark") %>"
                      data-label-system="<%= t("layout.theme_system") %>">
                  <%= initial_theme_label %>
                </span>
              </button>

              <% if user_signed_in? %>
                <div class="my-1 border-t border-surface-200 dark:border-surface-800" role="separator"></div>
                <%= button_to t("auth.sign_out"), destroy_user_session_path, method: :delete, form_class: "block", class: "block w-full px-4 py-2 text-left text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:text-surface-300 dark:hover:bg-surface-800 dark:hover:text-surface-50" %>
              <% end %>
            </div>
          </div>
        </nav>
      </div>
    </header>

    <main id="main" class="mx-auto max-w-5xl px-6 py-12">
      <div id="flash_container">
        <%= render "shared/flashes" %>
      </div>
      <%= render "shared/locale_banner" %>
      <%= yield %>
    </main>

    <%
      footer_link_base   = "transition-colors hover:text-accent-700 dark:hover:text-accent-400"
      footer_link_active = "text-accent-700 underline underline-offset-4 decoration-accent-700/40 dark:text-accent-400 dark:decoration-accent-400/40"
    %>
    <footer class="border-t border-surface-200 bg-surface-50 dark:border-surface-800 dark:bg-surface-950">
      <div class="mx-auto max-w-5xl space-y-6 px-6 py-8 sm:py-10">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div class="space-y-1">
            <p class="inline-flex items-center gap-2.5 font-ui text-base font-semibold text-surface-900 dark:text-surface-50">
              <span class="wordmark-mark" aria-hidden="true"></span>
              <%= t("app.name") %>
            </p>
            <p class="hidden font-reading text-sm text-surface-600 dark:text-surface-400 sm:block">
              <%= t("layout.footer_tagline") %>
            </p>
          </div>

          <nav class="flex flex-wrap items-center gap-4 font-ui text-sm text-surface-600 dark:text-surface-400">
            <% if donate_link_visible? %>
              <%= link_to t("layout.donate_link"), donate_path, class: "#{footer_link_base} #{footer_link_active if nav_active?(donate_path)}" %>
            <% end %>
            <%= link_to t("layout.how_it_works_link"), how_it_works_path, class: "#{footer_link_base} #{footer_link_active if nav_active?(how_it_works_path)}" %>
            <%= link_to t("layout.about_link"), about_path, class: "#{footer_link_base} #{footer_link_active if nav_active?(about_path)}" %>
            <% if user_signed_in? %>
              <%= link_to t("auth.settings"), settings_path, class: "#{footer_link_base} #{footer_link_active if nav_active?(settings_path)}" %>
            <% end %>
          </nav>
        </div>

        <%# Attribution row. Translations line stays sans because it
            carries proper-noun-case content ("Reina-Valera", "English")
            that loses information under text-transform: uppercase. The
            meta line ("No tracking. © 2026.") is short, no proper-
            nouns, and benefits from the deliberate mono-caps trust-
            signal rhythm — JetBrains Mono finally pays its dues here.
            text-[10px] compensates for the tracking-widest visual
            scale-up so the line doesn't outsize the translations
            line above it. %>
        <div class="flex items-end justify-between gap-4 border-t border-surface-200 pt-4 dark:border-surface-800">
          <div class="space-y-1">
            <%# text-balance asks the browser to balance line widths so
                the parentheticals ("(English)", "(Spanish)") don't drop
                to an orphan third line at narrow viewports. Falls back
                to default wrapping in browsers that don't support it. %>
            <p class="font-ui text-xs text-balance text-surface-500 dark:text-surface-400">
              <%= t("layout.footer_attribution_translations") %>
            </p>
            <p class="font-mono text-[10px] uppercase tracking-widest text-surface-500 dark:text-surface-400">
              <%= t("layout.footer_attribution_meta", year: Date.current.year) %>
            </p>
          </div>

          <%# Language toggle lives here so it's always reachable without
              opening the account menu — one tap regardless of auth state. %>
          <div class="flex gap-1" aria-label="<%= t("layout.language_switcher") %>">
            <% User::UI_LOCALES.each do |code| %>
              <% active = I18n.locale.to_s == code %>
              <% locale_classes = "rounded px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest transition-colors #{active ? "bg-surface-200 text-surface-900 dark:bg-surface-700 dark:text-surface-50" : "text-surface-400 hover:text-surface-600 dark:text-surface-500 dark:hover:text-surface-300"}" %>
              <% if user_signed_in? %>
                <%= button_to code.upcase, settings_path, method: :patch, params: { user: { ui_locale: code } }, form_class: "inline", class: locale_classes, aria: { label: t("layout.language_#{code}"), current: active ? "true" : nil } %>
              <% else %>
                <%= link_to code.upcase, url_for(locale: code), class: locale_classes, data: { turbo_prefetch: "false" }, aria: { label: t("layout.language_#{code}"), current: active ? "true" : nil } %>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </footer>

    <%# Note editor slide-in. Echo card chrome: at sm+ the panel is a
        fixed-width card from the right edge with rounded-l corners
        (reads as "sliding card" rather than "screen plane"); at <sm
        the panel is full-width edge-to-edge so rounding the corners
        would clip awkwardly. shadow-2xl gives the elevation in light
        mode. In dark mode both panel bg and page bg are surface-950,
        so shadow alone leaves the edge invisible — the explicit
        dark:border-l + dark:border-surface-800 gives the panel a
        readable edge against the page. The note_panel_controller.js
        slide-in transform mechanic is untouched. %>
    <aside id="note-panel-container"
           class="fixed inset-y-0 right-0 w-full max-w-full translate-x-full transform bg-surface-50 shadow-2xl transition-transform duration-150 ease-out sm:max-w-md sm:rounded-l-2xl dark:border-l dark:border-surface-800 dark:bg-surface-950"
           aria-label="Note editor">
      <div class="h-full overflow-y-auto p-5 sm:p-6">
        <%= turbo_frame_tag "note_panel" %>
      </div>
    </aside>
  </body>
</html>
