<%# A single public note card in the homepage community grid. Mirrors
    the hero verse card chrome but at a smaller scale (3-up grid).
    Locals: note (Note), verse (Verse). %>
<% chapter = verse.chapter %>
<% book = chapter.book %>
<% translation = book.translation %>

<%= link_to public_bible_chapter_path(translation: translation.code.downcase, book: book.osis_code.downcase, chapter: chapter.number),
            class: "block h-full rounded-2xl border border-surface-200 bg-surface-50 p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-surface-900 hover:shadow-[0_16px_40px_-16px_rgba(14,20,17,0.14)] dark:border-surface-800 dark:bg-surface-900 dark:hover:border-surface-50 dark:hover:shadow-[0_24px_48px_-16px_rgba(0,0,0,0.4)] sm:p-6" do %>
  <p class="font-mono text-[11px] font-semibold uppercase tracking-widest text-surface-500 dark:text-surface-400">
    <%= I18n.locale == :es ? book.name_es : book.name_en %> <%= chapter.number %> · <%= verse.number %> · <%= translation.code.upcase %>
  </p>

  <p class="mt-3 line-clamp-2 font-reading text-base leading-snug text-surface-900 dark:text-surface-100">
    <%= render_verse_with_highlights(verse, Array(note.highlights)) %>
  </p>

  <div class="mt-3 line-clamp-3 font-reading text-sm leading-relaxed text-surface-700 dark:text-surface-300">
    <%= note.body %>
  </div>

  <p class="mt-4 font-ui text-xs font-medium text-surface-600 dark:text-surface-400">
    — <%= link_to note.user.author_name, author_path(note.user), class: "transition-colors hover:text-accent-700 dark:hover:text-accent-400" %>
  </p>
<% end %>
