<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc><%= root_url %></loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc><%= about_url %></loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  <url>
    <loc><%= donate_url %></loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  <url>
    <loc><%= search_url %></loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  <% @translations.each do |translation| %>
    <% translation.books.order(:position).each do |book| %>
      <% book.chapters.order(:number).each do |chapter| %>
  <url>
    <loc><%= public_bible_chapter_url(translation: translation.code.downcase, book: book.osis_code.downcase, chapter: chapter.number) %></loc>
    <changefreq>yearly</changefreq>
    <priority>0.6</priority>
  </url>
      <% end %>
    <% end %>
  <% end %>
</urlset>
