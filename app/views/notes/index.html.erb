<% content_for :title, t("notes.my_notes") %>

<article class="mx-auto max-w-3xl space-y-8">
  <header class="border-b border-surface-200 pb-6 dark:border-surface-800">
    <h1 class="font-ui text-4xl font-semibold tracking-tight text-surface-900 dark:text-surface-50 sm:text-5xl">
      <%= t("notes.my_notes") %>
    </h1>
  </header>

  <% if @notes.any? %>
    <ul class="space-y-3">
      <% @notes.each do |note| %>
        <%
          badge_color = case note.visibility
          when "public_note"    then "bg-accent-100 text-accent-800 dark:bg-accent-900/40 dark:text-accent-300"
          when "friends_note", "shared_users", "shared_groups"
                                then "bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300"
          else                       "bg-surface-100 text-surface-600 dark:bg-surface-800 dark:text-surface-400"
          end
        %>
        <li class="rounded-2xl border border-surface-200 bg-surface-50 p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-surface-900 hover:shadow-[0_12px_32px_-12px_rgba(14,20,17,0.12)] dark:border-surface-800 dark:bg-surface-900 dark:hover:border-surface-50 dark:hover:shadow-[0_16px_40px_-16px_rgba(0,0,0,0.4)] sm:p-6">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1 space-y-2">
              <% if note.highlights.any? %>
                <p class="font-ui text-xs uppercase tracking-widest text-surface-500 dark:text-surface-400">
                  <%= note.highlights.first.osis_ref %>
                </p>
              <% end %>
              <div class="line-clamp-3 font-reading text-sm leading-relaxed text-surface-700 dark:text-surface-300">
                <%= note.body.to_plain_text.truncate(160) %>
              </div>
            </div>
            <div class="flex shrink-0 flex-col items-end gap-2">
              <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 font-ui text-xs font-medium <%= badge_color %>">
                <%= visibility_glyph(note) %>
                <%= t("notes.badge.#{note.visibility}") %>
              </span>
              <%= link_to t("groups.edit"), edit_note_path(note),
                          class: "font-ui text-xs text-surface-500 transition-colors hover:text-accent-700 dark:text-surface-400 dark:hover:text-accent-400" %>
            </div>
          </div>
          <p class="mt-3 font-ui text-xs text-surface-400 dark:text-surface-500">
            <%= l(note.updated_at, format: :long) %>
          </p>
        </li>
      <% end %>
    </ul>
  <% else %>
    <%# Design-v3 empty state: solid hairline card, friendly sans
        sentence, real button CTA — no dashed boxes, no italics. %>
    <div class="rounded-2xl border border-surface-200 bg-surface-100/60 px-8 py-12 text-center dark:border-surface-800 dark:bg-surface-900/60">
      <p class="font-ui text-sm text-surface-600 dark:text-surface-400">
        <%= t("notes.empty") %>
      </p>
      <%= link_to t("home.cta_public_bible"), bible_entry_path,
                  class: "mt-5 inline-block rounded-full bg-accent-700 px-5 py-2 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800 dark:bg-accent-400 dark:text-surface-950 dark:hover:bg-accent-300" %>
    </div>
  <% end %>
</article>
