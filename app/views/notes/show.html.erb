<%= turbo_frame_tag dom_id(@note) do %>
  <article class="rounded border border-walnut-900/15 bg-parchment-50 p-5 dark:border-gilt-500/30 dark:bg-walnut-800">
    <header class="mb-3 flex items-start justify-between gap-2">
      <p class="font-display text-xs uppercase tracking-[0.18em] text-walnut-900/70 dark:text-amber-200/70">
        <%= @note.highlights.map(&:osis_ref).join(", ") %>
      </p>
    </header>

    <div class="trix-content font-serif text-walnut-900 dark:text-amber-200">
      <%= @note.body %>
    </div>
  </article>
<% end %>
