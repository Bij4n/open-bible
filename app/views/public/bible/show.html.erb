<% book_name = I18n.locale == :es ? @book.name_es : @book.name_en %>

<article class="relative mx-auto max-w-3xl space-y-8">
  <header class="space-y-3 border-b border-surface-200 pb-6 dark:border-surface-800">
    <div class="flex items-center justify-between gap-3">
      <p class="font-ui text-xs font-medium uppercase tracking-wider text-surface-500 dark:text-surface-400">
        <%= @translation.name %> · <%= t("public_bible.community_view") %>
      </p>
      <div class="flex items-center gap-2">
        <%= render "bible/reader/layer_switcher",
                   translation: @translation, book: @book, chapter: @chapter,
                   selected_url: public_bible_chapter_path(translation: @translation.code.downcase, book: @book.osis_code.downcase, chapter: @chapter.number) %>
        <% translations = Translation.order(:name) %>
        <% if translations.size > 1 %>
          <%= render "shared/nav_select",
                     options: translations.map { |t|
                       [ t.name, public_bible_chapter_path(translation: t.code.downcase, book: @book.osis_code.downcase, chapter: @chapter.number) ]
                     },
                     selected_url: public_bible_chapter_path(translation: @translation.code.downcase, book: @book.osis_code.downcase, chapter: @chapter.number),
                     aria_label: t("bible.reader.translation_picker") %>
        <% end %>
      </div>
    </div>
    <h1 class="font-ui text-4xl font-semibold leading-[1.05] tracking-[-0.025em] text-surface-900 dark:text-surface-50 sm:text-5xl md:text-6xl">
      <span class="book-title-text"><%= book_name %> <%= @chapter.number %></span>
    </h1>
    <p class="max-w-2xl pt-1 font-reading text-sm leading-[1.6] text-pretty text-surface-600 dark:text-surface-400">
      <%= t("public_bible.intro") %>
    </p>
    <% if user_signed_in? %>
      <p class="font-ui text-sm text-surface-600 dark:text-surface-400">
        <%= link_to t("public_bible.switch_to_my_bible"),
                    bible_chapter_path(translation: @translation.code.downcase,
                                       book: @book.osis_code.downcase,
                                       chapter: @chapter.number),
                    class: "underline underline-offset-2 transition-colors hover:text-accent-700 dark:hover:text-accent-400" %>
      </p>
    <% end %>
  </header>

  <div class="chapter-body font-reading text-surface-900 dark:text-surface-100">
    <% chip_map = verse_note_map(@highlights) %>
    <% @verses.each_with_index do |verse, i| %><% chip_ids = chip_map[verse.id] || [] %><%= render partial: "bible/reader/verse", locals: { verse: verse, highlights: @highlights, highlight_style: :underline, chapter_opener: i == 0, note_chip: (chip_ids.any? ? { count: chip_ids.size, href: "#note_#{chip_ids.first}" } : nil) } %><%= " " unless i == @verses.size - 1 %><% end %>
  </div>

  <aside id="public_notes_aside" class="space-y-4">
    <h2 class="font-ui text-lg font-semibold tracking-tight text-surface-900 dark:text-surface-50">
      <%= t("public_bible.community_notes") %>
    </h2>

    <% if @public_notes.any? %>
      <ul id="public_notes_list" class="space-y-4">
        <% @public_notes.each do |note| %>
          <%= render partial: "public/bible/note", locals: { note: note } %>
        <% end %>
      </ul>
    <% else %>
      <p class="font-ui text-sm text-surface-600 dark:text-surface-400">
        <%= t("public_bible.no_notes_yet") %>
        <% unless user_signed_in? %>
          <%= link_to t("public_bible.sign_in_to_add"), new_user_session_path,
                      class: "ml-1 underline underline-offset-2 transition-colors hover:text-accent-700 dark:hover:text-accent-400" %>
        <% end %>
      </p>
    <% end %>
  </aside>
</article>
