<% content_for :title, t("donations.title") %>
<%
  card_classes  = "rounded-2xl border border-surface-200 bg-surface-50 p-6 dark:border-surface-800 dark:bg-surface-900"
  label_classes = "mb-1.5 block font-ui text-sm font-medium text-surface-900 dark:text-surface-100"
  input_classes = "w-full rounded-md border border-surface-300 bg-surface-50 px-3 py-2 font-ui text-sm text-surface-900 transition-colors placeholder:text-surface-500 focus:border-accent-700 focus:outline-none focus:ring-2 focus:ring-accent-700/20 dark:border-surface-700 dark:bg-surface-900 dark:text-surface-100 dark:focus:border-accent-400 dark:focus:ring-accent-400/20"
  submit_classes = "rounded-full bg-accent-700 px-5 py-2.5 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800 dark:bg-accent-400 dark:text-surface-950 dark:hover:bg-accent-300"
%>

<article class="mx-auto max-w-2xl space-y-8">
  <header class="space-y-3 border-b border-surface-200 pb-6 dark:border-surface-800">
    <h1 class="font-ui text-3xl font-semibold tracking-tight text-surface-900 dark:text-surface-50">
      <%= t("donations.title") %>
    </h1>
    <p class="font-reading text-base leading-relaxed text-surface-700 dark:text-surface-300">
      <%= t("donations.intro_html").html_safe %>
    </p>
  </header>

  <% if @address %>
    <section class="<%= card_classes %> space-y-5"
             data-controller="copy"
             data-copy-copied-value="<%= t("donations.copied") %>">
      <h2 class="font-ui text-lg font-semibold text-surface-900 dark:text-surface-50">
        <%= t("donations.address_heading") %>
      </h2>

      <div class="flex flex-col items-center gap-4 sm:flex-row sm:items-start">
        <%# QR renders identically in light + dark themes: black modules
            on white background. Wallet cameras assume the QR-code spec's
            black-on-white contract; tinting either side breaks scans on
            real-world hardware even when the WCAG ratio passes. The
            outer card around this block keeps its theme-aware styling. %>
        <div class="qr-frame shrink-0 rounded-md border border-surface-300 bg-white p-4 text-black"
             role="img"
             aria-label="<%= t("donations.qr_alt") %>">
          <%= @qr_svg %>
        </div>

        <div class="min-w-0 flex-1 space-y-3">
          <button type="button"
                  data-action="copy#copy"
                  class="group flex w-full items-center gap-2 rounded-md border border-surface-300 bg-surface-50 px-3 py-2 text-left transition-colors hover:border-accent-700 dark:border-surface-700 dark:bg-surface-950 dark:hover:border-accent-400">
            <code data-copy-target="source"
                  class="flex-1 break-all font-mono text-xs text-surface-900 dark:text-surface-100">
              <%= @address.address %>
            </code>
            <span data-copy-target="label"
                  class="shrink-0 font-ui text-xs font-medium text-accent-700 dark:text-accent-400">
              <%= t("donations.copy") %>
            </span>
          </button>
          <p class="font-ui text-xs text-surface-600 dark:text-surface-400">
            <%= t("donations.address_hint") %>
          </p>
        </div>
      </div>
    </section>

    <section class="<%= card_classes %> space-y-5">
      <header class="space-y-1.5">
        <h2 class="font-ui text-lg font-semibold text-surface-900 dark:text-surface-50">
          <%= t("donations.confirm_heading") %>
        </h2>
        <p class="font-reading text-sm leading-relaxed text-surface-700 dark:text-surface-300">
          <%= t("donations.confirm_intro") %>
        </p>
      </header>

      <%= form_with url: donate_confirm_path, scope: :donation_report, method: :post, class: "space-y-4" do |f| %>
        <%# Honeypot — sr-only field bots fill but humans don't see. %>
        <div class="sr-only" aria-hidden="true">
          <label for="website">Leave this field empty</label>
          <input type="text" name="website" id="website" tabindex="-1" autocomplete="off">
        </div>

        <div>
          <%= f.label :email, t("donations.email_label"), class: label_classes %>
          <%= f.email_field :email,
                            placeholder: t("donations.email_placeholder"),
                            autocomplete: "email",
                            class: input_classes %>
        </div>

        <div>
          <%= f.label :message, t("donations.message_label"), class: label_classes %>
          <%= f.text_area :message,
                          rows: 3,
                          maxlength: 2000,
                          placeholder: t("donations.message_placeholder"),
                          class: input_classes %>
        </div>

        <div class="flex justify-end">
          <%= f.submit t("donations.submit"), class: submit_classes %>
        </div>
      <% end %>
    </section>
  <% else %>
    <section class="<%= card_classes %> space-y-3">
      <h2 class="font-ui text-lg font-semibold text-surface-900 dark:text-surface-50">
        <%= t("donations.unavailable.heading") %>
      </h2>
      <p class="font-reading text-sm leading-relaxed text-surface-700 dark:text-surface-300">
        <%= t("donations.unavailable.body") %>
      </p>
    </section>
  <% end %>
</article>
