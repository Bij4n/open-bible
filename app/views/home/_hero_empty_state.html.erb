<%# Shown in the hero right-column when no admin-featured public note
    exists. Links to the public KJV reader so visitors can explore and
    eventually leave their own note. Verse text is static (John 3:16 KJV
    / RV1909) — no DB query; same visual frame as _hero_verse_card. %>
<%= link_to public_bible_chapter_path(translation: "kjv", book: "john", chapter: 3),
            data: { testid: "hero-empty-state" },
            class: "block rounded-2xl border border-surface-200 bg-surface-50 p-7 transition-all duration-200 hover:-translate-y-0.5 hover:border-surface-900 hover:shadow-[0_24px_60px_-20px_rgba(14,20,17,0.18)] dark:border-surface-800 dark:bg-surface-900 dark:hover:border-surface-50 dark:hover:shadow-[0_30px_60px_-30px_rgba(0,0,0,0.6)] sm:p-8" do %>
  <div class="flex items-start justify-between gap-3">
    <p class="font-ui text-[11px] font-semibold uppercase tracking-widest text-surface-500 dark:text-surface-400">
      <%= t("home.hero_empty_state.ref") %>
    </p>
    <p class="font-ui text-[11px] font-semibold uppercase tracking-widest text-surface-500 dark:text-surface-400">
      KJV
    </p>
  </div>

  <p class="mt-4 font-reading text-2xl leading-snug text-surface-900 text-pretty dark:text-surface-100">
    <%= t("home.hero_empty_state.verse") %>
  </p>

  <div class="mt-5 rounded-md bg-surface-100 p-4 font-reading text-base leading-relaxed text-surface-700 dark:bg-surface-950/50 dark:text-surface-300">
    <p class="italic"><%= t("home.hero_empty_state.cta") %></p>
  </div>
<% end %>
