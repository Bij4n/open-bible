<% verses = results[:verses] %>
<% notes  = results[:notes] %>

<% if verses.empty? && notes.empty? %>
  <p class="rounded-md border border-surface-200 bg-surface-100 px-4 py-3 font-ui text-sm text-surface-700 dark:border-surface-800 dark:bg-surface-800 dark:text-surface-300">
    <%= t("search.no_results_html", query: h(query)).html_safe %>
  </p>
<% else %>
  <p class="font-ui text-sm text-surface-600 dark:text-surface-400">
    <%= t("search.results_for_html", query: h(query)).html_safe %>
  </p>

  <% if verses.any? %>
    <section class="space-y-3">
      <h2 class="font-ui text-lg font-semibold tracking-tight text-surface-900 dark:text-surface-50">
        <%= t("search.verses_heading") %>
        <span class="ml-2 font-normal text-sm text-surface-500 dark:text-surface-400">(<%= verses.size %>)</span>
      </h2>
      <ul class="space-y-2">
        <% verses.each do |verse| %>
          <%= render partial: "verse_result", locals: { verse: verse } %>
        <% end %>
      </ul>
      <% if verses.size >= SearchService::VERSE_LIMIT %>
        <p class="font-ui text-xs italic text-surface-500 dark:text-surface-400">
          <%= t("search.showing_top", limit: SearchService::VERSE_LIMIT) %>
        </p>
      <% end %>
    </section>
  <% end %>

  <% if notes.any? %>
    <section class="space-y-3">
      <h2 class="font-ui text-lg font-semibold tracking-tight text-surface-900 dark:text-surface-50">
        <%= t("search.notes_heading") %>
        <span class="ml-2 font-normal text-sm text-surface-500 dark:text-surface-400">(<%= notes.size %>)</span>
      </h2>
      <ul class="space-y-3">
        <% notes.each do |note| %>
          <%= render partial: "note_result", locals: { note: note, query: query } %>
        <% end %>
      </ul>
    </section>
  <% end %>
<% end %>
