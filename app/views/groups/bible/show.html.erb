<% book_name = I18n.locale == :es ? @book.name_es : @book.name_en %>
<% debug_selection = Rails.env.development? || params[:debug] == "1" %>

<article class="relative mx-auto max-w-3xl space-y-8"
         data-controller="highlight"
         data-highlight-translation-code-value="<%= @translation.code %>"
         data-highlight-book-value="<%= @book.osis_code %>"
         data-highlight-chapter-value="<%= @chapter.number %>"
         data-highlight-debug-value="<%= debug_selection %>">

  <%= turbo_stream_from @group, "bible", @translation.code, @book.osis_code, @chapter.number,
                        channel: "GroupBibleChannel" %>

  <nav aria-label="breadcrumb" class="flex items-center gap-2 font-ui text-xs text-surface-600 dark:text-surface-400">
    <%= link_to t("bible.reader.breadcrumb_home"), root_path, class: "transition-colors hover:text-accent-700 dark:hover:text-accent-400" %>
    <span aria-hidden="true">&rsaquo;</span>
    <%= link_to @group.name, group_path(@group), class: "transition-colors hover:text-accent-700 dark:hover:text-accent-400" %>
    <span aria-hidden="true">&rsaquo;</span>
    <span class="text-surface-900 dark:text-surface-100"><%= book_name %> <%= @chapter.number %></span>
  </nav>

  <header class="space-y-3 border-b border-surface-200 pb-6 dark:border-surface-800">
    <p class="font-ui text-xs font-medium uppercase tracking-wider text-surface-500 dark:text-surface-400">
      <%= @translation.name %>
    </p>
    <h1 class="font-ui text-4xl font-semibold tracking-tight text-surface-900 dark:text-surface-50">
      <span class="book-title-text"><%= book_name %> <%= @chapter.number %></span>
    </h1>
  </header>

  <div class="chapter-body font-reading text-lg leading-relaxed text-surface-900 dark:text-surface-100"
       data-highlight-target="chapter">
    <% @verses.each_with_index do |verse, i| %><%= render partial: "bible/reader/verse", locals: { verse: verse, highlights: @highlights, chapter_opener: i == 0 } %><%= " " unless i == @verses.size - 1 %><% end %>
  </div>

  <aside id="group_notes_aside"
         class="rounded-lg border border-surface-200 bg-surface-50 p-5 dark:border-surface-800 dark:bg-surface-900 <%= "hidden" if @group_notes.empty? %>">
    <h2 class="font-ui text-lg font-semibold tracking-tight text-surface-900 dark:text-surface-50">
      <%= t("bible.reader.group_notes") %>
    </h2>
    <ul id="group_notes_list" class="mt-3 space-y-4">
      <% @group_notes.each do |note| %>
        <%= render partial: "groups/bible/note", locals: { note: note } %>
      <% end %>
    </ul>
  </aside>
</article>
