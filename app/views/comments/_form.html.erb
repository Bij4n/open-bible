<% placeholder = parent ? t("comments.reply_placeholder") : t("comments.add_placeholder") %>
<% submit_label = parent ? t("comments.reply") : t("comments.post") %>

<%= form_with model: Comment.new, url: comments_path, data: { turbo_frame: "_top" }, class: "space-y-2" do |f| %>
  <%= f.hidden_field :note_id, value: note.id %>
  <%= f.hidden_field :parent_id, value: parent&.id %>
  <%= f.text_area :body,
                  placeholder: placeholder,
                  rows: parent ? 2 : 3,
                  maxlength: Comment::BODY_MAX,
                  class: "w-full rounded-md border border-surface-300 bg-surface-50 px-3 py-2 font-ui text-sm text-surface-900 transition-colors placeholder:text-surface-500 focus:border-accent-700 focus:outline-none focus:ring-2 focus:ring-accent-700/20 dark:border-surface-700 dark:bg-surface-900 dark:text-surface-100 dark:focus:border-accent-400 dark:focus:ring-accent-400/20" %>
  <div class="flex items-center justify-end">
    <%= f.submit submit_label,
                 class: "rounded-md bg-accent-700 px-3 py-1.5 font-ui text-xs font-medium text-surface-50 transition-colors hover:bg-accent-800 dark:bg-accent-400 dark:text-surface-950 dark:hover:bg-accent-300" %>
  </div>
<% end %>
