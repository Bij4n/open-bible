<% heading  = t(".title", resource: devise_i18n_fix_model_name_case(resource.model_name.human, i18n_key: "registrations.edit.title")) %>
<% submit   = t(".update") %>
<% pw_hint  = t(".leave_blank_if_you_don_t_want_to_change_it") %>
<% cp_hint  = t(".we_need_your_current_password_to_confirm_your_changes") %>
<% cancel_h = t(".cancel_my_account") %>
<% unhappy  = t(".unhappy") %>
<% sure     = t(".are_you_sure") %>
<%
  label_classes  = "mb-1.5 block font-ui text-sm font-medium text-surface-900 dark:text-surface-100"
  input_classes  = "w-full rounded-md border border-surface-300 bg-surface-50 px-3 py-2 font-ui text-sm text-surface-900 transition-colors placeholder:text-surface-500 focus:border-accent-700 focus:outline-none focus:ring-2 focus:ring-accent-700/20 dark:border-surface-700 dark:bg-surface-900 dark:text-surface-100 dark:focus:border-accent-400 dark:focus:ring-accent-400/20"
  hint_classes   = "mb-1.5 font-ui text-xs text-surface-600 dark:text-surface-400"
  submit_classes = "w-full rounded-full bg-accent-700 px-4 py-2.5 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800 dark:bg-accent-400 dark:text-surface-950 dark:hover:bg-accent-300"
%>

<%= render "devise/shared/auth_shell", heading: heading do %>
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: label_classes %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: input_classes %>
    </div>

    <div>
      <%= f.label :password, class: label_classes %>
      <p class="<%= hint_classes %>"><%= pw_hint %></p>
      <%= f.password_field :password, autocomplete: "new-password", class: input_classes %>
      <% if @minimum_password_length %>
        <p class="mt-1.5 font-ui text-xs text-surface-600 dark:text-surface-400">
          <%= t("devise.shared.minimum_password_length", count: @minimum_password_length) %>
        </p>
      <% end %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: label_classes %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: input_classes %>
    </div>

    <div>
      <%= f.label :current_password, class: label_classes %>
      <p class="<%= hint_classes %>"><%= cp_hint %></p>
      <%= f.password_field :current_password, autocomplete: "current-password", class: input_classes %>
    </div>

    <%= f.submit submit, class: submit_classes %>
  <% end %>

  <div class="mt-8 border-t border-surface-200 pt-6 dark:border-surface-800">
    <h3 class="font-ui text-sm font-semibold text-surface-900 dark:text-surface-100">
      <%= cancel_h %>
    </h3>
    <p class="mt-2 font-ui text-sm text-surface-600 dark:text-surface-400">
      <%= unhappy %>
    </p>
    <%= button_to cancel_h,
                  registration_path(resource_name),
                  data: { confirm: sure, turbo_confirm: sure },
                  method: :delete,
                  class: "mt-3 rounded-md border border-red-500/40 bg-transparent px-3 py-1.5 font-ui text-xs font-medium text-red-700 transition-colors hover:bg-red-500 hover:text-surface-50 dark:border-red-400/40 dark:text-red-300 dark:hover:bg-red-500 dark:hover:text-surface-50" %>
  </div>

  <p class="mt-6 text-center font-ui text-sm">
    <%= link_to t("devise.shared.links.back"), :back, class: "text-surface-600 transition-colors hover:text-accent-700 dark:text-surface-400 dark:hover:text-accent-400" %>
  </p>
<% end %>
