<% content_for :title, t("groups.title") %>

<article class="mx-auto max-w-3xl space-y-10">
  <header class="flex items-end justify-between gap-4 border-b border-walnut-900/15 pb-6 dark:border-gilt-500/30">
    <div class="space-y-1">
      <p class="text-sm uppercase tracking-[0.3em] text-walnut-700/70 dark:text-amber-200/60">
        <%= t("groups.mine") %>
      </p>
      <h1 class="font-display text-4xl font-semibold uppercase tracking-[0.1em] text-walnut-900 dark:text-amber-200">
        <%= t("groups.title") %>
      </h1>
    </div>
    <%= link_to t("groups.new"),
                new_group_path,
                class: "rounded bg-walnut-900 px-4 py-2 font-display text-sm font-medium uppercase tracking-wider text-parchment-100 hover:bg-walnut-800 dark:bg-amber-200 dark:text-walnut-900 dark:hover:bg-amber-100" %>
  </header>

  <% if @groups.any? %>
    <ul class="space-y-3">
      <% @groups.each do |group| %>
        <li class="rounded border border-walnut-900/15 bg-parchment-50 p-4 dark:border-gilt-500/30 dark:bg-walnut-800">
          <div class="flex items-start justify-between gap-3">
            <div>
              <%= link_to group.name, group_path(group),
                          class: "font-display text-xl text-walnut-900 hover:text-rubric-500 dark:text-amber-200 dark:hover:text-gilt-400" %>
              <p class="font-serif text-sm text-walnut-700 dark:text-amber-300">
                <%= group.description.presence %>
              </p>
            </div>
            <span class="text-xs uppercase tracking-wider text-walnut-700/70 dark:text-amber-200/60">
              <%= group.owner_id == current_user.id ? t("groups.role.owner") : t("groups.role.member") %>
            </span>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="font-serif italic text-walnut-700 dark:text-amber-300">
      <%= t("groups.empty") %>
    </p>
  <% end %>

  <section class="rounded border border-walnut-900/15 bg-parchment-50 p-5 dark:border-gilt-500/30 dark:bg-walnut-800">
    <h2 class="font-display text-lg uppercase tracking-wider text-walnut-900 dark:text-amber-200">
      <%= t("groups.enter_code") %>
    </h2>
    <%= form_with url: join_groups_path, method: :post, class: "mt-3 flex gap-2" do |f| %>
      <%= f.text_field :invitation_code,
                       required: true,
                       placeholder: t("groups.invitation_code"),
                       class: "flex-1 rounded border border-walnut-900/25 bg-parchment-50 px-3 py-2 font-mono text-walnut-900 focus:border-walnut-900 focus:outline-none dark:border-gilt-500/40 dark:bg-walnut-900 dark:text-amber-200" %>
      <%= f.submit t("groups.join"),
                   class: "rounded bg-walnut-900 px-4 py-2 font-display text-sm font-medium uppercase tracking-wider text-parchment-100 hover:bg-walnut-800 dark:bg-amber-200 dark:text-walnut-900 dark:hover:bg-amber-100" %>
    <% end %>
  </section>
</article>
