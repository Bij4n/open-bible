<section class="space-y-0.5 border-t border-surface-200 pt-3 dark:border-surface-800">
  <h3 class="font-ui text-xs font-semibold uppercase tracking-wider text-surface-500 dark:text-surface-400">
    <%= t("comments.title") %>
    <span class="ml-2 font-normal normal-case tracking-normal text-surface-500 dark:text-surface-500">
      (<%= note.comments.count %>)
    </span>
  </h3>

  <div id="comments_thread_<%= note.id %>" class="space-y-1">
    <% note.comments_in_thread_order.each do |comment| %>
      <%= render partial: "comments/comment", locals: { comment: comment } %>
    <% end %>
  </div>

  <div id="comment_form_<%= note.id %>" class="mt-3">
    <%= render partial: "comments/form", locals: { note: note, parent: nil } %>
  </div>
</section>
