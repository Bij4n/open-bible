<% content_for :title, @group.name %>
<% is_owner = @group.owner_id == current_user.id %>
<%
  primary_btn   = "rounded-full bg-accent-700 px-5 py-2 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800 dark:bg-accent-400 dark:text-surface-950 dark:hover:bg-accent-300"
  secondary_btn = "rounded-full border border-surface-300 px-5 py-2 font-ui text-sm font-medium text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:border-surface-700 dark:text-surface-300 dark:hover:bg-surface-800 dark:hover:text-surface-50"
  danger_btn    = "rounded-md border border-red-500/40 bg-transparent px-4 py-2 font-ui text-sm font-medium text-red-700 transition-colors hover:bg-red-500 hover:text-surface-50 dark:border-red-400/40 dark:text-red-300 dark:hover:bg-red-500 dark:hover:text-surface-50"
  danger_sm_btn = "rounded-md border border-red-500/40 bg-transparent px-2.5 py-1 font-ui text-xs font-medium text-red-700 transition-colors hover:bg-red-500 hover:text-surface-50 dark:border-red-400/40 dark:text-red-300 dark:hover:bg-red-500 dark:hover:text-surface-50"
  input_classes = "w-full rounded-md border border-surface-300 bg-surface-50 px-3 py-2 font-ui text-sm text-surface-900 transition-colors placeholder:text-surface-500 focus:border-accent-700 focus:outline-none focus:ring-2 focus:ring-accent-700/20 dark:border-surface-700 dark:bg-surface-900 dark:text-surface-100 dark:focus:border-accent-400 dark:focus:ring-accent-400/20"
%>

<article class="mx-auto max-w-3xl space-y-8">
  <header class="space-y-2 border-b border-surface-200 pb-6 dark:border-surface-800">
    <p class="font-ui text-xs font-medium uppercase tracking-wider text-surface-500 dark:text-surface-400">
      <%= t("groups.privacy.#{@group.privacy}") %>
    </p>
    <h1 class="font-ui text-4xl font-semibold tracking-tight text-surface-900 dark:text-surface-50">
      <%= @group.name %>
    </h1>
    <% if @group.description.present? %>
      <p class="font-reading text-surface-700 dark:text-surface-300">
        <%= @group.description %>
      </p>
    <% end %>
  </header>

  <div class="flex flex-wrap items-center gap-3">
    <%= link_to t("groups.bible"),
                group_bible_chapter_path(@group, translation: "kjv", book: "gen", chapter: 1),
                class: primary_btn %>
    <% if is_owner %>
      <%= link_to t("groups.edit"), edit_group_path(@group), class: secondary_btn %>
      <%= button_to t("groups.destroy"),
                    group_path(@group),
                    method: :delete,
                    form_class: "inline",
                    data: { turbo_confirm: t("groups.destroy") + "?" },
                    class: danger_btn %>
    <% else %>
      <%= button_to t("groups.leave"),
                    leave_group_path(@group),
                    method: :delete,
                    form_class: "inline",
                    data: { turbo_confirm: t("groups.leave") + "?" },
                    class: secondary_btn %>
    <% end %>
  </div>

  <% if is_owner && @group.invitation_code.present? %>
    <section class="rounded-2xl border border-surface-200 bg-surface-50 p-5 dark:border-surface-800 dark:bg-surface-900">
      <h2 class="font-ui text-xs font-semibold uppercase tracking-wider text-surface-500 dark:text-surface-400">
        <%= t("groups.invitation_code") %>
      </h2>
      <p class="mt-2 font-mono text-2xl text-surface-900 dark:text-surface-100">
        <%= @group.invitation_code %>
      </p>
    </section>
  <% end %>

  <section>
    <h2 class="font-ui text-lg font-semibold tracking-tight text-surface-900 dark:text-surface-50">
      <%= t("groups.members") %>
    </h2>
    <ul class="mt-3 space-y-2">
      <% @memberships.each do |m| %>
        <li class="flex items-center justify-between rounded-md border border-surface-200 bg-surface-50 px-4 py-2 dark:border-surface-800 dark:bg-surface-900">
          <span class="font-ui text-sm text-surface-900 dark:text-surface-100">
            <%= m.user.author_name %>
          </span>
          <div class="flex items-center gap-3">
            <span class="font-ui text-xs uppercase tracking-wider text-surface-500 dark:text-surface-400">
              <%= t("groups.role.#{m.role}") %>
            </span>
            <% if is_owner && m.user_id != current_user.id %>
              <%= button_to t("memberships.remove"),
                            group_membership_path(@group, m),
                            method: :delete,
                            form_class: "inline",
                            data: { turbo_confirm: t("memberships.remove") + "?" },
                            class: danger_sm_btn %>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>

    <% if is_owner %>
      <%= form_with url: group_memberships_path(@group), method: :post, class: "mt-4 flex gap-2" do |f| %>
        <%= f.email_field :email,
                          required: true,
                          placeholder: t("memberships.email_placeholder"),
                          class: input_classes %>
        <%= f.submit t("memberships.add_member"), class: primary_btn %>
      <% end %>
    <% end %>
  </section>
</article>
