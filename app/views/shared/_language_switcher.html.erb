<div class="flex items-center gap-2">
  <span class="sr-only"><%= t("layout.language_switcher") %>:</span>

  <% User::UI_LOCALES.each_with_index do |code, i| %>
    <% label  = t("layout.language_#{code}") %>
    <% active = I18n.locale.to_s == code %>
    <% link_classes = "hover:text-rubric-500 dark:hover:text-gilt-400 #{"underline underline-offset-4" if active}" %>

    <% if user_signed_in? %>
      <%# Signed in — PATCH the user's ui_locale then bounce back. %>
      <%= button_to label,
                    settings_path,
                    method: :patch,
                    params: { user: { ui_locale: code } },
                    form_class: "inline",
                    class: link_classes %>
    <% else %>
      <%# Signed out — params[:locale] writes through to the session. %>
      <%= link_to label, url_for(locale: code), class: link_classes %>
    <% end %>

    <% unless i == User::UI_LOCALES.length - 1 %>
      <span aria-hidden="true" class="text-walnut-900/40 dark:text-amber-200/40">·</span>
    <% end %>
  <% end %>
</div>
