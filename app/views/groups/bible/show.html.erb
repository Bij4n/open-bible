<% book_name = I18n.locale == :es ? @book.name_es : @book.name_en %>
<% debug_selection = Rails.env.development? || params[:debug] == "1" %>

<article class="relative mx-auto max-w-3xl space-y-8"
         data-controller="highlight"
         data-highlight-translation-code-value="<%= @translation.code %>"
         data-highlight-book-value="<%= @book.osis_code %>"
         data-highlight-chapter-value="<%= @chapter.number %>"
         data-highlight-debug-value="<%= debug_selection %>">

  <%= turbo_stream_from @group, "bible", @translation.code, @book.osis_code, @chapter.number,
                        channel: "GroupBibleChannel" %>

  <nav aria-label="breadcrumb" class="flex items-center gap-2 text-xs uppercase tracking-wider text-walnut-700 dark:text-amber-300">
    <%= link_to t("bible.reader.breadcrumb_home"), root_path, class: "hover:text-rubric-500 dark:hover:text-gilt-400" %>
    <span aria-hidden="true">&rsaquo;</span>
    <%= link_to @group.name, group_path(@group), class: "hover:text-rubric-500 dark:hover:text-gilt-400" %>
    <span aria-hidden="true">&rsaquo;</span>
    <span class="text-walnut-900 dark:text-amber-200"><%= book_name %> <%= @chapter.number %></span>
  </nav>

  <header class="space-y-1 border-b border-walnut-900/15 pb-6 dark:border-gilt-500/30">
    <p class="text-sm uppercase tracking-[0.3em] text-walnut-700/70 dark:text-amber-200/60">
      <%= @translation.name %>
    </p>
    <h1 class="font-display text-5xl font-semibold uppercase tracking-[0.1em] text-walnut-900 dark:text-amber-200">
      <%= book_name %> <%= @chapter.number %>
    </h1>
  </header>

  <div class="chapter-body font-serif text-lg leading-loose text-walnut-900 dark:text-amber-200"
       data-highlight-target="chapter">
    <% @verses.each_with_index do |verse, i| %><%= render partial: "bible/reader/verse", locals: { verse: verse, highlights: @highlights } %><%= " " unless i == @verses.size - 1 %><% end %>
  </div>

  <aside id="group_notes_aside"
         class="rounded border border-walnut-900/15 bg-parchment-50 p-5 dark:border-gilt-500/30 dark:bg-walnut-800 <%= "hidden" if @group_notes.empty? %>">
    <h2 class="font-display text-lg uppercase tracking-wider text-walnut-900 dark:text-amber-200">
      <%= t("bible.reader.group_notes") %>
    </h2>
    <ul id="group_notes_list" class="mt-3 space-y-4">
      <% @group_notes.each do |note| %>
        <%= render partial: "groups/bible/note", locals: { note: note } %>
      <% end %>
    </ul>
  </aside>
</article>
