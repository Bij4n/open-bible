<% content_for :title, t("admin.notes.title") %>

<article class="mx-auto max-w-3xl space-y-6">
  <header class="space-y-1 border-b border-walnut-900/15 pb-4 dark:border-gilt-500/30">
    <p class="text-sm uppercase tracking-[0.3em] text-walnut-700/70 dark:text-amber-200/60">
      <%= t("admin.title") %>
    </p>
    <h1 class="font-display text-2xl uppercase tracking-[0.08em] text-walnut-900 dark:text-amber-200">
      <%= @note.highlights.map(&:osis_ref).join(", ") %>
    </h1>
    <p class="font-serif text-sm italic text-walnut-700 dark:text-amber-300">
      by <%= @note.user.author_name %>
    </p>
  </header>

  <div class="trix-content font-serif">
    <%= @note.body %>
  </div>

  <section>
    <h2 class="font-display text-sm uppercase tracking-wider text-walnut-900/70 dark:text-amber-200/70">
      <%= t("admin.notes.header_flags") %> (<%= @note.flags.unresolved.size %>)
    </h2>
    <ul class="mt-2 space-y-2 font-serif text-sm">
      <% @note.flags.unresolved.includes(:user).each do |flag| %>
        <li class="rounded border border-walnut-900/10 px-3 py-2 dark:border-gilt-500/20">
          <strong><%= flag.reason %></strong> — <%= flag.user.author_name %>
          <% if flag.details.present? %><em class="ml-1"><%= flag.details %></em><% end %>
        </li>
      <% end %>
    </ul>
  </section>
</article>
