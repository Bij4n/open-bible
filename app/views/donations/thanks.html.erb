<% content_for :title, t("donations.thank_you.heading") %>

<article class="mx-auto max-w-xl space-y-6 text-center">
  <h1 class="font-ui text-3xl font-semibold tracking-tight text-surface-900 dark:text-surface-50">
    <%= t("donations.thank_you.heading") %>
  </h1>
  <p class="font-reading text-base leading-relaxed text-surface-700 dark:text-surface-300">
    <%= t("donations.thank_you.body") %>
  </p>
  <div class="pt-2">
    <%= link_to t("donations.thank_you.back_to_reading"),
                public_bible_chapter_path(translation: "kjv", book: "gen", chapter: 1),
                class: "rounded-full bg-accent-700 px-5 py-2.5 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800 dark:bg-accent-400 dark:text-surface-950 dark:hover:bg-accent-300" %>
  </div>
</article>
