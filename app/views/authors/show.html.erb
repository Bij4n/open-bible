<% content_for :title, @author.author_name %>

<article class="mx-auto max-w-3xl space-y-8">
  <header class="border-b border-surface-200 pb-6 dark:border-surface-800">
    <p class="font-ui text-xs font-medium uppercase tracking-wider text-surface-500 dark:text-surface-400">
      <%= t("authors.member_since", year: @author.created_at.year) %>
    </p>
    <h1 class="mt-2 font-ui text-4xl font-semibold tracking-tight text-surface-900 dark:text-surface-50 sm:text-5xl">
      <%= @author.author_name %>
    </h1>
  </header>

  <section>
    <h2 class="mb-4 font-ui text-lg font-semibold text-surface-900 dark:text-surface-50">
      <%= t("authors.public_notes_heading") %>
    </h2>

    <% if @notes.any? %>
      <ul class="space-y-3">
        <% @notes.each do |note| %>
          <li class="rounded-2xl border border-surface-200 bg-surface-50 p-5 dark:border-surface-800 dark:bg-surface-900 sm:p-6">
            <% if note.highlights.any? %>
              <p class="font-mono text-xs uppercase tracking-widest text-surface-500 dark:text-surface-400">
                <%= note.highlights.first.osis_ref %>
              </p>
            <% end %>
            <div class="mt-2 trix-content font-reading text-surface-900 dark:text-surface-100">
              <%= note.body %>
            </div>
            <p class="mt-3 font-ui text-xs text-surface-400 dark:text-surface-500">
              <%= l(note.updated_at, format: :long) %>
            </p>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="rounded-2xl border border-dashed border-surface-300 px-8 py-12 text-center dark:border-surface-700">
        <p class="font-reading italic text-surface-500 dark:text-surface-400">
          <%= t("authors.no_public_notes") %>
        </p>
      </div>
    <% end %>
  </section>
</article>
