<li id="<%= dom_id(note) %>"
    data-controller="<%= user_signed_in? ? "upvote flag" : "" %>"
    data-upvote-note-id-value="<%= note.id %>"
    data-upvote-upvoted-value="<%= note.upvoted_by?(current_user) %>"
    data-flag-note-id-value="<%= note.id %>"
    data-flag-prompt-value="<%= t("public_bible.flag_reason_prompt") %>"
    data-flag-success-value="<%= t("public_bible.flag_submitted") %>"
    data-flag-failure-value="<%= t("public_bible.flag_failed") %>"
    class="rounded-2xl border <%= note.featured? ? "border-accent-400/60" : "border-surface-200" %> bg-surface-50 p-4 dark:border-surface-800 dark:bg-surface-900 <%= "ring-1 ring-accent-400/30" if note.featured? %> <%= "opacity-60" if note.hidden? %>">
  <header class="flex items-start justify-between gap-3">
    <div>
      <p class="font-ui text-xs uppercase tracking-wider text-surface-500 dark:text-surface-400">
        <%= note.highlights.map(&:osis_ref).join(", ") %>
        <span class="ml-2 italic normal-case tracking-normal">
          <%= t("public_bible.by_author_html", name: link_to(note.user.author_name, author_path(note.user), class: "transition-colors hover:text-accent-700 dark:hover:text-accent-400")) %>
        </span>
      </p>
      <% if note.featured? %>
        <span class="mt-1 inline-block rounded-full bg-accent-700/10 px-2.5 py-0.5 font-ui text-xs font-medium tracking-wide text-accent-700 dark:bg-accent-400/10 dark:text-accent-400">
          ★ <%= t("public_bible.featured") %>
        </span>
      <% end %>
      <% if note.hidden? %>
        <span class="mt-1 inline-block rounded-full bg-red-500/10 px-2.5 py-0.5 font-ui text-xs font-medium tracking-wide text-red-700 dark:text-red-300">
          <%= t("public_bible.hidden") %>
        </span>
      <% end %>
    </div>

    <div class="flex items-center gap-2 font-ui text-xs">
      <% if user_signed_in? %>
        <button type="button"
                data-upvote-target="button"
                data-action="upvote#toggle"
                class="rounded-full border border-surface-300 px-2.5 py-1 transition-colors hover:border-surface-500 dark:border-surface-700 dark:hover:border-surface-500 <%= "bg-accent-700 text-surface-50 dark:bg-accent-400 dark:text-surface-950" if note.upvoted_by?(current_user) %>">
          <span>&#9650;</span>
          <span data-upvote-target="count"><%= note.upvote_count %></span>
        </button>
        <button type="button"
                data-action="flag#prompt"
                class="text-surface-600 transition-colors hover:text-accent-700 dark:text-surface-400 dark:hover:text-accent-400"
                title="<%= t("public_bible.flag") %>">
          <%= t("public_bible.flag") %>
        </button>
      <% else %>
        <span class="inline-flex items-center gap-1 text-surface-600 dark:text-surface-400">
          <span>&#9650;</span>
          <span><%= note.upvote_count %></span>
        </span>
      <% end %>
    </div>
  </header>

  <div class="trix-content mt-2 font-reading text-surface-900 dark:text-surface-100">
    <%= note.body %>
  </div>

  <%= render partial: "comments/thread", locals: { note: note } %>
</li>
