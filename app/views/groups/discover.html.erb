<% content_for :title, t("groups.discover_title") %>

<article class="mx-auto max-w-3xl space-y-8">
  <header class="border-b border-surface-200 pb-6 dark:border-surface-800">
    <p class="font-ui text-xs font-medium uppercase tracking-wider text-surface-500 dark:text-surface-400">
      <%= t("app.name") %>
    </p>
    <h1 class="mt-2 font-ui text-4xl font-semibold tracking-tight text-surface-900 dark:text-surface-50 sm:text-5xl">
      <%= t("groups.discover_title") %>
    </h1>
    <p class="mt-3 font-reading text-base text-surface-600 dark:text-surface-400">
      <%= t("groups.discover_subtitle") %>
    </p>
  </header>

  <% if @groups.any? %>
    <ul class="space-y-3">
      <% @groups.each do |group| %>
        <li class="rounded-2xl border border-surface-200 bg-surface-50 p-5 dark:border-surface-800 dark:bg-surface-900 sm:p-6">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1 space-y-1">
              <h2 class="font-ui text-lg font-semibold text-surface-900 dark:text-surface-50">
                <%= group.name %>
              </h2>
              <% if group.description.present? %>
                <p class="font-reading text-sm leading-relaxed text-surface-600 dark:text-surface-400">
                  <%= group.description %>
                </p>
              <% end %>
              <p class="font-ui text-xs text-surface-500 dark:text-surface-400">
                <%= t("groups.member_count", count: group.memberships.size) %>
              </p>
            </div>
            <div class="shrink-0">
              <% if user_signed_in? %>
                <% if group.member?(current_user) %>
                  <%= link_to t("groups.bible"), group_bible_chapter_path(group, "kjv", "gen", 1),
                              class: "rounded-full border border-accent-700 px-4 py-1.5 font-ui text-sm font-medium text-accent-700 transition-colors hover:bg-accent-50 dark:border-accent-400 dark:text-accent-400 dark:hover:bg-accent-900/20" %>
                <% else %>
                  <%= button_to t("groups.join_open"), join_groups_path,
                                method: :post,
                                params: { group_id: group.id },
                                class: "rounded-full bg-accent-700 px-4 py-1.5 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800 dark:bg-accent-400 dark:text-surface-950 dark:hover:bg-accent-300" %>
                <% end %>
              <% else %>
                <%= link_to t("groups.join_open"), new_user_session_path,
                            class: "rounded-full bg-accent-700 px-4 py-1.5 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800 dark:bg-accent-400 dark:text-surface-950 dark:hover:bg-accent-300" %>
              <% end %>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="rounded-2xl border border-dashed border-surface-300 px-8 py-12 text-center dark:border-surface-700">
      <p class="font-reading italic text-surface-500 dark:text-surface-400">
        <%= t("groups.discover_empty") %>
      </p>
      <% if user_signed_in? %>
        <%= link_to t("groups.new"), new_group_path,
                    class: "mt-4 inline-block font-ui text-sm text-accent-700 underline underline-offset-4 decoration-accent-700/40 hover:text-accent-800 dark:text-accent-400 dark:decoration-accent-400/40 dark:hover:text-accent-300" %>
      <% end %>
    </div>
  <% end %>
</article>
