<% indent = [ comment.depth, Comment::MAX_DEPTH ].min * 20 %>
<article id="<%= dom_id(comment) %>"
         data-controller="comment"
         data-depth="<%= comment.depth %>"
         class="comment mt-2"
         style="margin-left: <%= indent %>px;">
  <header class="flex items-center justify-between gap-2 text-xs text-walnut-700/80 dark:text-amber-200/70">
    <span>
      <strong class="font-display uppercase tracking-[0.08em] text-walnut-900 dark:text-amber-200">
        <%= comment.user.author_name %>
      </strong>
      <span class="ml-2 italic">
        <%= t("comments.timestamp", ago: time_ago_in_words(comment.created_at)) %>
      </span>
    </span>
  </header>

  <div class="mt-1 whitespace-pre-wrap font-serif text-sm text-walnut-900 dark:text-amber-200">
    <%= comment.body %>
  </div>

  <footer class="mt-1 flex items-center gap-3 text-xs text-walnut-700 dark:text-amber-300">
    <% if comment.depth < Comment::MAX_DEPTH %>
      <button type="button"
              data-action="comment#toggleReply"
              class="hover:text-rubric-500 dark:hover:text-gilt-400">
        <%= t("comments.reply") %>
      </button>
    <% end %>

    <% if comment.user_id == current_user&.id %>
      <%= button_to t("comments.delete"),
                    comment_path(comment),
                    method: :delete,
                    form_class: "inline",
                    data: { turbo_confirm: t("comments.confirm_delete") },
                    class: "hover:text-rubric-500 dark:hover:text-gilt-400" %>
    <% end %>
  </footer>

  <div data-comment-target="replyForm" class="mt-2 hidden">
    <%= render partial: "comments/form", locals: { note: comment.note, parent: comment } %>
  </div>
</article>
