<% book_name = I18n.locale == :es ? @book.name_es : @book.name_en %>
<% prev_chapter = @chapter.previous %>
<% next_chapter = @chapter.next %>
<% debug_selection = Rails.env.development? || params[:debug] == "1" %>

<article class="relative mx-auto max-w-3xl space-y-8"
         data-controller="highlight"
         data-highlight-translation-code-value="<%= @translation.code %>"
         data-highlight-book-value="<%= @book.osis_code %>"
         data-highlight-chapter-value="<%= @chapter.number %>"
         data-highlight-debug-value="<%= debug_selection %>">
  <nav aria-label="<%= t("bible.reader.chapter_label") %>" class="flex items-center justify-between gap-4 font-ui text-sm">
    <% if prev_chapter %>
      <%= link_to t("bible.reader.prev_chapter"),
                  bible_chapter_path(translation: @translation.code.downcase,
                                     book: prev_chapter.book.osis_code.downcase,
                                     chapter: prev_chapter.number),
                  class: "text-surface-600 transition-colors hover:text-accent-700 dark:text-surface-400 dark:hover:text-accent-400" %>
    <% else %>
      <span aria-hidden="true"></span>
    <% end %>

    <%= render "shared/nav_select",
               options: @book.chapters.order(:number).map { |ch|
                 [ "#{t('bible.reader.chapter_label')} #{ch.number}",
                   bible_chapter_path(translation: @translation.code.downcase, book: @book.osis_code.downcase, chapter: ch.number) ]
               },
               selected_url: bible_chapter_path(translation: @translation.code.downcase, book: @book.osis_code.downcase, chapter: @chapter.number),
               aria_label: t("bible.reader.chapter_label") %>

    <% if next_chapter %>
      <%= link_to t("bible.reader.next_chapter"),
                  bible_chapter_path(translation: @translation.code.downcase,
                                     book: next_chapter.book.osis_code.downcase,
                                     chapter: next_chapter.number),
                  class: "text-surface-600 transition-colors hover:text-accent-700 dark:text-surface-400 dark:hover:text-accent-400" %>
    <% else %>
      <span aria-hidden="true"></span>
    <% end %>
  </nav>

  <header class="space-y-4 border-b border-surface-200 pb-7 dark:border-surface-800">
    <div class="flex items-center justify-between gap-3">
      <%# Translation NAMES are mixed-case proper nouns ("King James
          Version", "Reina-Valera 1909"); mono-caps would erase the
          information. Sans uppercase tracked-out is the right eyebrow
          treatment here. %>
      <p class="font-ui text-xs font-medium uppercase tracking-widest text-surface-500 dark:text-surface-400">
        <%= @translation.name %>
      </p>
      <% translations = Translation.order(:name) %>
      <% if translations.size > 1 %>
        <%= render "shared/nav_select",
                   options: translations.map { |t|
                     [ t.name, bible_chapter_path(translation: t.code.downcase, book: @book.osis_code.downcase, chapter: @chapter.number) ]
                   },
                   selected_url: bible_chapter_path(translation: @translation.code.downcase, book: @book.osis_code.downcase, chapter: @chapter.number),
                   aria_label: t("bible.reader.translation_picker") %>
      <% end %>
    </div>
    <h1 class="font-ui text-4xl font-semibold leading-[1.05] tracking-[-0.025em] text-surface-900 dark:text-surface-50 sm:text-5xl md:text-6xl">
      <span class="book-title-text"><%= book_name %> <%= @chapter.number %></span>
    </h1>
  </header>

  <div class="chapter-body font-reading text-lg leading-relaxed text-surface-900 dark:text-surface-100"
       data-highlight-target="chapter">
    <% @verses.each_with_index do |verse, i| %><%= render partial: "bible/reader/verse", locals: { verse: verse, highlights: @highlights || [], cross_translation_highlights: @cross_translation_highlights, chapter_opener: i == 0 } %><%= " " unless i == @verses.size - 1 %><% end %>
  </div>

  <% if user_signed_in? %>
    <!-- toolbar interaction polish (pencil → note bridge, highlight removal) tracked for Sprint 16.5 -->
    <div data-highlight-target="toolbar"
         hidden
         class="absolute z-20 flex items-center gap-1 rounded-xl border border-surface-200 bg-surface-50 p-1.5 shadow-xl ring-1 ring-surface-900/5 dark:border-surface-800 dark:bg-surface-900 dark:ring-surface-50/10">
      <% Highlight::COLORS.each do |color| %>
        <%# aria-pressed flips to "true" on the swatch matching the
            existing highlight color under the current selection (set
            by highlight#markActiveSwatch). The aria-pressed:ring-*
            utilities draw an inset ink ring on the active swatch.
            ring color is surface-900 in BOTH modes — the swatch fills
            don't theme-flip (PR 1 left them at full opacity, applied
            identically in both themes), so a near-white dark-mode
            ring would vanish on the pale pastel fills (verified
            1.50–1.69:1 across all 5). surface-900 holds 9.45–10.62:1
            on every swatch. %>
        <button type="button"
                data-action="highlight#apply"
                data-color="<%= color %>"
                title="<%= color.capitalize %>"
                aria-pressed="false"
                class="h-6 w-6 rounded-full border border-surface-300 transition-transform hover:scale-110 aria-pressed:ring-2 aria-pressed:ring-inset aria-pressed:ring-surface-900 dark:border-surface-700 highlight-swatch-<%= color %>">
          <span class="sr-only"><%= color.capitalize %></span>
        </button>
      <% end %>
      <button type="button"
              data-action="highlight#note"
              title="<%= t("notes.save", default: "Note") %>"
              class="h-6 rounded-md px-2 font-ui text-xs text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:text-surface-300 dark:hover:bg-surface-800 dark:hover:text-surface-50">
        &#9998;
      </button>
      <button type="button"
              data-action="highlight#remove"
              title="<%= t("bible.reader.remove_highlight", default: "Remove") %>"
              class="h-6 rounded-md px-2 font-ui text-xs text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:text-surface-300 dark:hover:bg-surface-800 dark:hover:text-surface-50">
        &times;
      </button>
    </div>
  <% end %>

  <nav aria-label="<%= t("bible.reader.chapter_label") %>" class="flex items-center justify-between border-t border-surface-200 pt-6 font-ui text-sm dark:border-surface-800">
    <% if prev_chapter %>
      <%= link_to t("bible.reader.prev_chapter"),
                  bible_chapter_path(translation: @translation.code.downcase,
                                     book: prev_chapter.book.osis_code.downcase,
                                     chapter: prev_chapter.number),
                  class: "text-surface-600 transition-colors hover:text-accent-700 dark:text-surface-400 dark:hover:text-accent-400" %>
    <% else %>
      <span aria-hidden="true"></span>
    <% end %>

    <% if next_chapter %>
      <%= link_to t("bible.reader.next_chapter"),
                  bible_chapter_path(translation: @translation.code.downcase,
                                     book: next_chapter.book.osis_code.downcase,
                                     chapter: next_chapter.number),
                  class: "text-surface-600 transition-colors hover:text-accent-700 dark:text-surface-400 dark:hover:text-accent-400" %>
    <% end %>
  </nav>
</article>
