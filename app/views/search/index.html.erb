<% content_for :title, t("search.title") %>
<%
  card_classes   = "rounded-2xl border border-surface-200 bg-surface-50 p-6 sm:p-8 dark:border-surface-800 dark:bg-surface-900"
  input_classes  = "flex-1 rounded-md border border-surface-300 bg-surface-50 px-3 py-2 font-ui text-sm text-surface-900 transition-colors placeholder:text-surface-500 focus:border-accent-700 focus:outline-none focus:ring-2 focus:ring-accent-700/20 dark:border-surface-700 dark:bg-surface-900 dark:text-surface-100 dark:focus:border-accent-400 dark:focus:ring-accent-400/20"
  submit_classes = "rounded-full bg-accent-700 px-5 py-2 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800 dark:bg-accent-400 dark:text-surface-950 dark:hover:bg-accent-300"
  banner_classes = "rounded-md border border-surface-200 bg-surface-100 px-4 py-3 font-ui text-sm text-surface-700 dark:border-surface-800 dark:bg-surface-800 dark:text-surface-300"
%>

<article class="mx-auto max-w-3xl space-y-8">
  <header class="space-y-2 border-b border-surface-200 pb-6 dark:border-surface-800">
    <h1 class="font-ui text-4xl font-semibold tracking-tight text-surface-900 dark:text-surface-50 sm:text-5xl">
      <%= t("search.title") %>
    </h1>
    <p class="font-reading italic text-surface-600 dark:text-surface-400">
      <%= t("search.subtitle") %>
    </p>
  </header>

  <%= form_with url: search_path, method: :get, class: "#{card_classes} space-y-4" do |f| %>
    <div class="flex gap-2">
      <%= f.text_field :q,
                       value: @query,
                       placeholder: t("search.input_placeholder"),
                       autofocus: true,
                       autocomplete: "off",
                       class: input_classes %>
      <%= f.submit t("search.submit"), class: submit_classes %>
    </div>

    <% available_modes = @semantic_available ? SearchController::MODES : %w[keyword] %>
    <% if available_modes.size > 1 %>
      <fieldset class="flex items-center gap-4 font-ui text-sm text-surface-700 dark:text-surface-300">
        <legend class="sr-only"><%= t("search.modes.keyword") %></legend>
        <% available_modes.each do |mode| %>
          <label class="flex items-center gap-1.5">
            <%= f.radio_button :mode, mode, checked: @mode == mode, class: "h-4 w-4 accent-accent-700 dark:accent-accent-400" %>
            <%= t("search.modes.#{mode}") %>
          </label>
        <% end %>
      </fieldset>
    <% end %>

    <fieldset class="flex items-center gap-4 font-ui text-sm text-surface-700 dark:text-surface-300">
      <legend class="sr-only"><%= t("search.filters.all") %></legend>
      <% SearchService::VALID_SCOPES.each do |scope| %>
        <label class="flex items-center gap-1.5">
          <%= f.radio_button :scope, scope, checked: @scope == scope, class: "h-4 w-4 accent-accent-700 dark:accent-accent-400" %>
          <%= t("search.filters.#{scope}") %>
        </label>
      <% end %>
    </fieldset>

    <% if Translation.count > 1 %>
      <fieldset class="flex items-center gap-4 font-ui text-sm text-surface-700 dark:text-surface-300">
        <legend class="sr-only"><%= t("search.translations.all") %></legend>
        <% SearchService::VALID_TRANSLATIONS.each do |ts| %>
          <label class="flex items-center gap-1.5">
            <%= f.radio_button :translations, ts, checked: @translations == ts, class: "h-4 w-4 accent-accent-700 dark:accent-accent-400" %>
            <%= t("search.translations.#{ts}") %>
          </label>
        <% end %>
      </fieldset>
      <%= f.hidden_field :translation_code, value: @translation_code %>
    <% end %>

    <% if @mode == "semantic" %>
      <p class="font-ui text-xs italic text-surface-500 dark:text-surface-400">
        <%= t("search.semantic_explanation") %>
      </p>
    <% end %>
  <% end %>

  <% if @query.present? %>
    <% if @results[:semantic_fallback] %>
      <p class="<%= banner_classes %>">
        <%= t("search.semantic_unavailable") %>
      </p>
    <% end %>

    <% if @results[:notes_scope_requested] %>
      <p class="<%= banner_classes %>">
        <%= t("search.semantic_notes_pending") %>
      </p>
    <% end %>

    <%= render partial: "results", locals: { results: @results, query: @query, scope: @scope } %>
  <% else %>
    <section class="<%= card_classes %> space-y-4">
      <p class="font-reading italic text-surface-600 dark:text-surface-400">
        <%= t("search.empty_hint") %>
      </p>
      <div>
        <h2 class="font-ui text-xs font-semibold uppercase tracking-wider text-surface-500 dark:text-surface-400">
          <%= t("search.suggestions_heading") %>
        </h2>
        <div class="mt-3 flex flex-wrap gap-2">
          <% t("search.suggestions").each do |term| %>
            <%= link_to term, search_path(q: term),
                        class: "rounded-full border border-surface-300 px-3 py-1 font-ui text-sm text-surface-700 transition-colors hover:border-accent-700 hover:text-accent-700 dark:border-surface-700 dark:text-surface-300 dark:hover:border-accent-400 dark:hover:text-accent-400" %>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>
</article>
