<!DOCTYPE html>
<%# resolved_theme is "light"/"dark" only when the signed-in user pinned
    it; otherwise the Stimulus controller decides on connect and we leave
    data-theme unset. That avoids a flash of the wrong palette for users
    who've saved a preference. %>
<html lang="<%= I18n.locale %>"<%= " data-theme=\"#{resolved_theme}\"".html_safe if resolved_theme %> data-controller="theme">
  <head>
    <title><%= content_for(:title) || t("app.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t("app.name") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Self-hosted fonts live in /public/fonts and are loaded via
        @font-face rules in application.css. No Google Fonts or other
        third-party hosts — see CLAUDE.md. %>
    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/SourceSerif4Variable-Roman.otf.woff2" as="font" type="font/woff2" crossorigin>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:rounded focus:bg-surface-900 focus:px-3 focus:py-1 focus:text-surface-50 font-ui">
      <%= t("layout.skip_to_content") %>
    </a>

    <header class="border-b border-surface-200 bg-surface-50 dark:border-surface-800 dark:bg-surface-950">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <%= link_to root_path, class: "font-ui text-lg font-semibold tracking-tight text-surface-900 transition-colors hover:text-accent-700 dark:text-surface-50 dark:hover:text-accent-400" do %>
          <%= t("app.name") %>
        <% end %>

        <nav class="flex items-center gap-1 font-ui text-sm" aria-label="<%= t("layout.account") %>">
          <%= link_to search_path, class: "rounded-md px-3 py-1.5 text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:text-surface-300 dark:hover:bg-surface-800 dark:hover:text-surface-50" do %>
            <%= t("search.submit") %>
          <% end %>

          <div data-controller="user-menu" class="relative">
            <button type="button"
                    data-user-menu-target="trigger"
                    data-action="user-menu#toggle"
                    aria-expanded="false"
                    aria-haspopup="true"
                    aria-label="<%= t("layout.open_menu") %>"
                    class="flex items-center gap-1.5 rounded-md px-3 py-1.5 text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:text-surface-300 dark:hover:bg-surface-800 dark:hover:text-surface-50">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                <path fill-rule="evenodd" d="M18 5.25a.75.75 0 0 1-.75.75H2.75a.75.75 0 0 1 0-1.5h14.5a.75.75 0 0 1 .75.75ZM18 10a.75.75 0 0 1-.75.75H2.75a.75.75 0 0 1 0-1.5h14.5A.75.75 0 0 1 18 10Zm0 4.75a.75.75 0 0 1-.75.75H2.75a.75.75 0 0 1 0-1.5h14.5a.75.75 0 0 1 .75.75Z" clip-rule="evenodd" />
              </svg>
              <span class="hidden sm:inline"><%= t("layout.account") %></span>
            </button>

            <div data-user-menu-target="menu"
                 hidden
                 role="menu"
                 aria-label="<%= t("layout.account") %>"
                 class="absolute right-0 z-20 mt-2 w-60 origin-top-right rounded-lg border border-surface-200 bg-surface-50 py-1 text-sm shadow-lg ring-1 ring-surface-900/5 dark:border-surface-800 dark:bg-surface-900 dark:ring-surface-50/10">

              <% if user_signed_in? %>
                <div class="px-4 py-2 text-xs uppercase tracking-wide text-surface-500 dark:text-surface-400">
                  <%= current_user.email %>
                </div>
                <div class="my-1 border-t border-surface-200 dark:border-surface-800" role="separator"></div>
                <% if current_user.admin? %>
                  <%= link_to admin_notes_path, role: "menuitem", class: "block px-4 py-2 text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:text-surface-300 dark:hover:bg-surface-800 dark:hover:text-surface-50" do %><%= t("admin.title") %><% end %>
                <% end %>
                <%= link_to settings_path, role: "menuitem", class: "block px-4 py-2 text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:text-surface-300 dark:hover:bg-surface-800 dark:hover:text-surface-50" do %><%= t("auth.settings") %><% end %>
              <% else %>
                <%#  Sign-up intentionally omitted — Devise's sign-in form
                     renders a "Sign up" link underneath via the shared
                     _links partial, which is one click away. Matches the
                     Grammarly/Notion/Linear/Stripe navbar pattern. %>
                <%= link_to new_user_session_path, role: "menuitem", class: "block px-4 py-2 text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:text-surface-300 dark:hover:bg-surface-800 dark:hover:text-surface-50" do %><%= t("auth.sign_in") %><% end %>
              <% end %>

              <div class="my-1 border-t border-surface-200 dark:border-surface-800" role="separator"></div>

              <button type="button"
                      data-action="theme#toggle"
                      role="menuitem"
                      aria-label="<%= t("layout.theme_switch") %>"
                      class="flex w-full items-center gap-2 px-4 py-2 text-left text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:text-surface-300 dark:hover:bg-surface-800 dark:hover:text-surface-50">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="theme-icon-sun h-4 w-4" aria-hidden="true">
                  <path d="M10 2a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0v-1.5A.75.75 0 0 1 10 2ZM10 15a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0v-1.5A.75.75 0 0 1 10 15ZM10 7a3 3 0 1 0 0 6 3 3 0 0 0 0-6ZM15.657 5.404a.75.75 0 0 0-1.06-1.06l-1.061 1.06a.75.75 0 1 0 1.06 1.06l1.06-1.06ZM6.464 14.596a.75.75 0 0 0-1.06-1.06l-1.06 1.06a.75.75 0 0 0 1.06 1.06l1.06-1.06ZM18 10a.75.75 0 0 1-.75.75h-1.5a.75.75 0 0 1 0-1.5h1.5A.75.75 0 0 1 18 10ZM5 10a.75.75 0 0 1-.75.75h-1.5a.75.75 0 0 1 0-1.5h1.5A.75.75 0 0 1 5 10ZM14.596 15.657a.75.75 0 0 0 1.06-1.06l-1.06-1.061a.75.75 0 1 0-1.06 1.06l1.06 1.06ZM5.404 6.464a.75.75 0 0 0 1.06-1.06l-1.06-1.06a.75.75 0 1 0-1.061 1.06l1.06 1.06Z" />
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="theme-icon-moon h-4 w-4" aria-hidden="true">
                  <path fill-rule="evenodd" d="M7.455 2.004a.75.75 0 0 1 .26.77 7 7 0 0 0 9.958 7.967.75.75 0 0 1 1.067.853A8.5 8.5 0 1 1 6.647 1.921a.75.75 0 0 1 .808.083Z" clip-rule="evenodd" />
                </svg>
                <span data-theme-target="label"
                      data-label-light="<%= t("layout.theme_light") %>"
                      data-label-dark="<%= t("layout.theme_dark") %>">
                  <%= resolved_theme == "dark" ? t("layout.theme_dark") : t("layout.theme_light") %>
                </span>
              </button>

              <div class="px-4 py-2">
                <div class="mb-1.5 text-xs uppercase tracking-wide text-surface-500 dark:text-surface-400">
                  <%= t("layout.language_switcher") %>
                </div>
                <div class="flex gap-1.5">
                  <% User::UI_LOCALES.each do |code| %>
                    <% label = t("layout.language_#{code}") %>
                    <% active = I18n.locale.to_s == code %>
                    <% locale_classes = "rounded-md px-2.5 py-1 text-xs font-medium transition-colors #{ active ? "bg-accent-700 text-surface-50 dark:bg-accent-400 dark:text-surface-950" : "text-surface-700 hover:bg-surface-100 dark:text-surface-300 dark:hover:bg-surface-800" }" %>
                    <% if user_signed_in? %>
                      <%= button_to label, settings_path, method: :patch, params: { user: { ui_locale: code } }, form_class: "inline", class: locale_classes %>
                    <% else %>
                      <%# data-turbo-prefetch="false": locale change writes
                          through to session via params, so hover-prefetch
                          would silently flip the user's UI language. Click
                          still navigates via Turbo as normal. %>
                      <%= link_to label, url_for(locale: code), role: "menuitem", class: locale_classes, data: { turbo_prefetch: "false" } %>
                    <% end %>
                  <% end %>
                </div>
              </div>

              <% if user_signed_in? %>
                <div class="my-1 border-t border-surface-200 dark:border-surface-800" role="separator"></div>
                <%= button_to t("auth.sign_out"), destroy_user_session_path, method: :delete, form_class: "block", class: "block w-full px-4 py-2 text-left text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900 dark:text-surface-300 dark:hover:bg-surface-800 dark:hover:text-surface-50" %>
              <% end %>
            </div>
          </div>
        </nav>
      </div>
    </header>

    <main id="main" class="mx-auto max-w-5xl px-6 py-12">
      <%= render "shared/flashes" %>
      <%= render "shared/locale_banner" %>
      <%= yield %>
    </main>

    <aside id="note-panel-container"
           class="fixed inset-y-0 right-0 w-full max-w-full translate-x-full transform border-l border-surface-200 bg-surface-50 shadow-xl transition-transform duration-150 ease-out sm:max-w-md dark:border-surface-800 dark:bg-surface-950"
           aria-label="Note editor">
      <div class="h-full overflow-y-auto p-5">
        <%= turbo_frame_tag "note_panel" %>
      </div>
    </aside>
  </body>
</html>
