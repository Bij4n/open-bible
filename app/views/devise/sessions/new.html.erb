<%= render "devise/shared/auth_shell", heading: t(".sign_in") do %>
  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
    <div>
      <%= f.label :email, class: "mb-1 block font-serif text-sm font-medium uppercase tracking-wider text-walnut-900/80 dark:text-amber-200/80" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
          class: "w-full rounded border border-walnut-900/25 bg-parchment-50 px-3 py-2 font-serif text-walnut-900 focus:border-walnut-900 focus:outline-none focus:ring-1 focus:ring-walnut-900 dark:border-gilt-500/40 dark:bg-walnut-900 dark:text-amber-200 dark:focus:border-gilt-400 dark:focus:ring-gilt-400" %>
    </div>

    <div>
      <%= f.label :password, class: "mb-1 block font-serif text-sm font-medium uppercase tracking-wider text-walnut-900/80 dark:text-amber-200/80" %>
      <%= f.password_field :password, autocomplete: "current-password",
          class: "w-full rounded border border-walnut-900/25 bg-parchment-50 px-3 py-2 font-serif text-walnut-900 focus:border-walnut-900 focus:outline-none focus:ring-1 focus:ring-walnut-900 dark:border-gilt-500/40 dark:bg-walnut-900 dark:text-amber-200 dark:focus:border-gilt-400 dark:focus:ring-gilt-400" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <label class="flex items-center gap-2 font-serif text-sm text-walnut-900 dark:text-amber-200">
        <%= f.check_box :remember_me, class: "rounded border-walnut-900/40 text-walnut-900 focus:ring-walnut-900 dark:border-gilt-500/40 dark:text-gilt-400 dark:focus:ring-gilt-400" %>
        <%= f.label :remember_me %>
      </label>
    <% end %>

    <%= f.submit t(".sign_in"), class: "w-full rounded bg-walnut-900 px-4 py-2 font-display text-sm font-medium uppercase tracking-wider text-parchment-100 hover:bg-walnut-800 dark:bg-amber-200 dark:text-walnut-900 dark:hover:bg-amber-100" %>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
