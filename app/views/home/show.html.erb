<%
  for_yourself_keys = %w[highlights notes keyword_search semantic_search]
  with_others_keys  = %w[groups public bilingual]
  feature_destinations = {
    "highlights"      => public_bible_chapter_path(translation: "kjv", book: "gen", chapter: 1),
    "notes"           => public_bible_chapter_path(translation: "kjv", book: "gen", chapter: 1),
    "groups"          => groups_path,
    "public"          => public_bible_chapter_path(translation: "kjv", book: "gen", chapter: 1),
    "bilingual"       => public_bible_chapter_path(translation: "rv1909", book: "gen", chapter: 1),
    "keyword_search"  => search_path,
    "semantic_search" => search_path
  }

  hero_btn     = "inline-flex items-center gap-2 rounded-full bg-surface-950 px-7 py-3.5 font-ui text-base font-medium text-surface-50 transition-colors hover:bg-accent-700 hover:-translate-y-px dark:bg-surface-50 dark:text-surface-950 dark:hover:bg-accent-400"
  donate_btn   = "inline-flex items-center gap-2 rounded-full bg-surface-50 px-7 py-3.5 font-ui text-base font-medium text-surface-950 transition-colors hover:bg-accent-300 hover:-translate-y-px"
  card_classes = "block h-full rounded-2xl border border-surface-200 bg-surface-50 p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-surface-900 hover:shadow-[0_16px_40px_-16px_rgba(14,20,17,0.14)] dark:border-surface-800 dark:bg-surface-900 dark:hover:border-surface-50 dark:hover:shadow-[0_24px_48px_-16px_rgba(0,0,0,0.4)] sm:p-6"
  section_h2   = "font-ui text-2xl font-semibold tracking-tight text-surface-900 dark:text-surface-50 sm:text-3xl"
  subgroup_h3  = "font-ui text-sm font-semibold uppercase tracking-widest text-surface-500 dark:text-surface-400"
%>

<div class="space-y-24 sm:space-y-28">
  <%# Hero %>
  <section class="space-y-5 pt-2 sm:space-y-6 sm:pt-4">
    <h1 class="hero-emphasis font-ui text-5xl font-semibold leading-[1.05] tracking-[-0.035em] text-surface-900 dark:text-surface-50 sm:text-6xl md:text-7xl">
      <%= t("home.welcome_html") %>
    </h1>
    <p class="max-w-2xl font-reading text-lg leading-[1.6] text-pretty text-surface-700 dark:text-surface-300 sm:text-xl">
      <%= t("home.subhead") %>
    </p>

    <div class="pt-2">
      <%= link_to t("home.cta_public_bible"),
                  public_bible_chapter_path(translation: "kjv", book: "gen", chapter: 1),
                  class: hero_btn %>
    </div>

    <p class="font-ui text-xs text-surface-500 dark:text-surface-400">
      <%= t("home.tertiary") %>
    </p>
  </section>

  <%# Features — split into two subgroups for visual rhythm and to
      mirror the product's two arcs (personal experience vs. shared
      experience). Bilingual lands in "With others" because the heart-
      language framing in its body is relational, not technical. %>
  <section class="space-y-10">
    <h2 class="<%= section_h2 %>">
      <%= t("home.features.heading") %>
    </h2>

    <div class="space-y-6">
      <h3 class="<%= subgroup_h3 %>">
        <%= t("home.features.for_yourself") %>
      </h3>
      <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <% for_yourself_keys.each do |key| %>
          <li>
            <%= link_to feature_destinations[key], class: card_classes do %>
              <h4 class="font-ui text-base font-semibold text-surface-900 dark:text-surface-50">
                <%= t("home.features.#{key}.title") %>
              </h4>
              <p class="mt-2 font-reading text-sm leading-relaxed text-surface-600 dark:text-surface-400">
                <%= t("home.features.#{key}.body") %>
              </p>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>

    <div class="space-y-6">
      <h3 class="<%= subgroup_h3 %>">
        <%= t("home.features.with_others") %>
      </h3>
      <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <% with_others_keys.each do |key| %>
          <li>
            <%= link_to feature_destinations[key], class: card_classes do %>
              <h4 class="font-ui text-base font-semibold text-surface-900 dark:text-surface-50">
                <%= t("home.features.#{key}.title") %>
              </h4>
              <p class="mt-2 font-reading text-sm leading-relaxed text-surface-600 dark:text-surface-400">
                <%= t("home.features.#{key}.body") %>
              </p>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </section>

  <%# How it works %>
  <section class="space-y-8">
    <h2 class="<%= section_h2 %>">
      <%= t("home.how.heading") %>
    </h2>

    <ol class="grid grid-cols-1 gap-8 sm:grid-cols-3 sm:gap-6">
      <% (1..3).each do |n| %>
        <li class="space-y-2.5">
          <%# Numeral: Instrument Serif italic 28px in a 44x44 mint
              disc. Echo's signal: steps read as considered (literary)
              rather than mechanical (sans counter). If production
              review reads it as decorative/precious, swap the active
              <div> below for the commented sans-bold revert (Rule 9
              fix-on-this-branch — delete-and-uncomment). %>
          <%# Sans-bold revert path:
          <div class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-accent-700/10 font-ui text-sm font-semibold text-accent-700 dark:bg-accent-400/10 dark:text-accent-400">
            <%= n %>
          </div>
          %>
          <div class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-accent-700/10 font-reading text-[28px] font-normal italic leading-none text-accent-700 dark:bg-accent-400/10 dark:text-accent-400">
            <%= n %>
          </div>
          <h3 class="font-ui text-base font-semibold text-surface-900 dark:text-surface-50">
            <%= t("home.how.step_#{n}_title") %>
          </h3>
          <p class="font-reading text-sm leading-relaxed text-surface-600 dark:text-surface-400">
            <%= t("home.how.step_#{n}_body") %>
          </p>
        </li>
      <% end %>
    </ol>
  </section>

  <%# About — 5 paragraphs by design. The strong line ("the verse
      that wrecks you...") sits as its own paragraph between the
      belief opener (p1) and its consequence (p3); translations
      (p4) and maintainer/funding (p5) split apart so the practical
      content doesn't run together in one breath. %>
  <section id="about" class="space-y-4">
    <h2 class="<%= section_h2 %>">
      <%= t("home.about.heading") %>
    </h2>
    <% (1..5).each do |n| %>
      <p class="max-w-2xl font-reading text-base leading-[1.7] text-pretty text-surface-700 dark:text-surface-300">
        <%= t("home.about.para_#{n}") %>
      </p>
    <% end %>
  </section>

  <%# Donate CTA — gated on the same active-address check as the
      footer link, so the donations affordance is uniformly visible
      or hidden site-wide. /donate itself stays accessible by URL
      with the unavailable explainer. %>
  <% if donate_link_visible? %>
    <%# Donate panel: .donate-callout chrome — dark statement in
        light mode, subtle elevation in dark mode, mint radial glow,
        inverse paper-on-ink button. If production review feels too
        heavy against the now-mint page, swap the active <section>
        below for the commented light-card revert (Rule 9 fix-on-
        this-branch — delete-and-uncomment). The light-card revert
        is self-contained: the donate_btn local stays in place but
        is unused inside the comment, the bg-accent-700 button class
        string is inlined so the revert needs no other edits. %>
    <%# Light-card revert path:
    <section data-section="donate-cta"
             class="rounded-lg border border-surface-200 bg-surface-50 p-7 text-center dark:border-surface-800 dark:bg-surface-900 sm:p-10">
      <h2 class="font-ui text-xl font-semibold tracking-tight text-surface-900 dark:text-surface-50 sm:text-2xl">
        <%= t("home.donate_cta.heading") %>
      </h2>
      <p class="mx-auto mt-3 max-w-md font-reading text-base leading-relaxed text-surface-700 dark:text-surface-300">
        <%= t("home.donate_cta.body") %>
      </p>
      <div class="mt-6">
        <%= link_to t("home.donate_cta.button"), donate_path, class: "inline-block rounded-md bg-accent-700 px-6 py-3.5 font-ui text-base font-medium text-surface-50 transition-colors hover:bg-accent-800 dark:bg-accent-400 dark:text-surface-950 dark:hover:bg-accent-300" %>
      </div>
    </section>
    %>
    <section data-section="donate-cta"
             class="donate-callout rounded-3xl p-8 text-center sm:p-12">
      <div class="relative">
        <h2 class="font-ui text-2xl font-semibold tracking-tight text-surface-50 sm:text-3xl">
          <%= t("home.donate_cta.heading") %>
        </h2>
        <p class="mx-auto mt-3 max-w-md font-reading text-base leading-[1.7] text-pretty text-surface-50/72">
          <%= t("home.donate_cta.body") %>
        </p>
        <div class="mt-7">
          <%= link_to t("home.donate_cta.button"), donate_path, class: donate_btn %>
        </div>
      </div>
    </section>
  <% end %>
</div>
