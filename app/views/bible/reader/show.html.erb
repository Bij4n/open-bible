<% book_name = I18n.locale == :es ? @book.name_es : @book.name_en %>
<% prev_chapter = @chapter.previous %>
<% next_chapter = @chapter.next %>
<% debug_selection = Rails.env.development? || params[:debug] == "1" %>

<article class="relative mx-auto max-w-3xl space-y-8"
         data-controller="highlight"
         data-highlight-translation-code-value="<%= @translation.code %>"
         data-highlight-book-value="<%= @book.osis_code %>"
         data-highlight-chapter-value="<%= @chapter.number %>"
         data-highlight-debug-value="<%= debug_selection %>">
  <nav aria-label="<%= t("bible.reader.chapter_label") %>" class="flex items-center justify-between gap-4 font-ui text-sm">
    <% if prev_chapter %>
      <%= link_to bible_chapter_path(translation: @translation.code.downcase,
                                     book: prev_chapter.book.osis_code.downcase,
                                     chapter: prev_chapter.number),
                  class: "inline-flex items-center gap-1 text-surface-600 transition-colors hover:text-accent-700 dark:text-surface-400 dark:hover:text-accent-400" do %>
        <span aria-hidden="true">&larr;</span>
        <%= t("bible.reader.prev_chapter") %>
      <% end %>
    <% else %>
      <span aria-hidden="true"></span>
    <% end %>

    <%= render "shared/nav_select",
               options: @book.chapters.order(:number).map { |ch|
                 [ "#{t('bible.reader.chapter_label')} #{ch.number}",
                   bible_chapter_path(translation: @translation.code.downcase, book: @book.osis_code.downcase, chapter: ch.number) ]
               },
               selected_url: bible_chapter_path(translation: @translation.code.downcase, book: @book.osis_code.downcase, chapter: @chapter.number),
               aria_label: t("bible.reader.chapter_label") %>

    <% if next_chapter %>
      <%= link_to bible_chapter_path(translation: @translation.code.downcase,
                                     book: next_chapter.book.osis_code.downcase,
                                     chapter: next_chapter.number),
                  class: "inline-flex items-center gap-1 text-surface-600 transition-colors hover:text-accent-700 dark:text-surface-400 dark:hover:text-accent-400" do %>
        <%= t("bible.reader.next_chapter") %>
        <span aria-hidden="true">&rarr;</span>
      <% end %>
    <% else %>
      <span aria-hidden="true"></span>
    <% end %>
  </nav>

  <header class="space-y-4 border-b border-surface-200 pb-7 dark:border-surface-800">
    <div class="flex items-center justify-between gap-3">
      <%# Translation NAMES are mixed-case proper nouns ("King James
          Version", "Reina-Valera 1909"); mono-caps would erase the
          information. Sans uppercase tracked-out is the right eyebrow
          treatment here. %>
      <p class="font-ui text-xs font-medium uppercase tracking-widest text-surface-500 dark:text-surface-400">
        <%= @translation.name %>
      </p>
      <div class="flex items-center gap-2">
        <%= render "bible/reader/layer_switcher",
                   translation: @translation, book: @book, chapter: @chapter,
                   selected_url: bible_chapter_path(translation: @translation.code.downcase, book: @book.osis_code.downcase, chapter: @chapter.number) %>
        <% translations = Translation.order(:name) %>
        <% if translations.size > 1 %>
          <%= render "shared/nav_select",
                     options: translations.map { |t|
                       [ t.name, bible_chapter_path(translation: t.code.downcase, book: @book.osis_code.downcase, chapter: @chapter.number) ]
                     },
                     selected_url: bible_chapter_path(translation: @translation.code.downcase, book: @book.osis_code.downcase, chapter: @chapter.number),
                     aria_label: t("bible.reader.translation_picker") %>
        <% end %>
      </div>
    </div>
    <h1 class="font-ui text-4xl font-semibold leading-[1.05] tracking-[-0.025em] text-surface-900 dark:text-surface-50 sm:text-5xl md:text-6xl">
      <span class="book-title-text"><%= book_name %> <%= @chapter.number %></span>
    </h1>
  </header>

  <div class="chapter-body font-reading text-surface-900 dark:text-surface-100"
       data-highlight-target="chapter">
    <% @verses.each_with_index do |verse, i| %><%= render partial: "bible/reader/verse", locals: { verse: verse, highlights: @highlights || [], cross_translation_highlights: @cross_translation_highlights, chapter_opener: i == 0 } %><%= " " unless i == @verses.size - 1 %><% end %>
  </div>

  <% if user_signed_in? %>
    <%# Sprint 16.5 PR C: confirm-remove templates carry the
        pluralized I18n forms as data attributes. JS picks `singular`
        when noteCount == 1, `plural` otherwise, then string-replaces
        the literal `%{count}` placeholder client-side. Rails escapes
        the attribute values automatically when the data: hash is
        used (vs raw inline `data-x="..."` which leaves us responsible
        for the escaping). %>
    <%# Medium-style dark pill toolbar (design v3): the labeled
        Highlight button is the one-click happy path (default color,
        zero decisions); the four swatches are the optional refinement.
        Dark in BOTH themes — it floats above the text like a tooltip,
        so it keeps tooltip chrome regardless of page theme. %>
    <%= tag.div data: {
                  highlight_target: "toolbar",
                  confirm_remove_singular: t("bible.reader.confirm_remove_with_notes.one", count: "%{count}"),
                  confirm_remove_plural:   t("bible.reader.confirm_remove_with_notes.other", count: "%{count}")
                },
                hidden: true,
                class: "toolbar-sheet absolute z-20 flex items-center gap-1 rounded-full bg-surface-900 px-1.5 py-1.5 shadow-lg ring-1 ring-surface-50/10 dark:bg-surface-800" do %>
      <%# data-highlight-default marks the one-click default action; it
          shares highlight#apply with the swatches via its data-color. %>
      <button type="button"
              data-action="highlight#apply"
              data-color="<%= Highlight::DEFAULT_COLOR %>"
              data-highlight-default
              class="h-7 rounded-full px-3 font-ui text-xs font-medium text-surface-50 transition-colors hover:bg-surface-700 dark:hover:bg-surface-700">
        <%= t("bible.reader.highlight_action") %>
      </button>
      <span class="h-4 w-px bg-surface-50/20" aria-hidden="true"></span>
      <% Highlight::TOOLBAR_COLORS.each do |color| %>
        <%# aria-pressed flips to "true" on the swatch matching the
            existing highlight color under the current selection (set
            by highlight#markActiveSwatch; legacy stored colors alias
            onto these four). The inset ring stays surface-900 ink —
            it draws on top of the pale pastel fill (9.4:1+), not on
            the pill background. %>
        <button type="button"
                data-action="highlight#apply"
                data-color="<%= color %>"
                title="<%= color.capitalize %>"
                aria-pressed="false"
                class="h-6 w-6 rounded-full border border-surface-50/25 transition-transform hover:scale-110 aria-pressed:ring-2 aria-pressed:ring-inset aria-pressed:ring-surface-900 highlight-swatch-<%= color %>">
          <span class="sr-only"><%= color.capitalize %></span>
        </button>
      <% end %>
      <span class="h-4 w-px bg-surface-50/20" aria-hidden="true"></span>
      <button type="button"
              data-action="highlight#note"
              title="<%= t("bible.reader.note_action") %>"
              class="h-7 rounded-full px-3 font-ui text-xs text-surface-50 transition-colors hover:bg-surface-700 dark:hover:bg-surface-700">
        <%= t("bible.reader.note_action") %>
      </button>
      <button type="button"
              data-action="highlight#dismiss"
              title="<%= t("bible.reader.dismiss_toolbar") %>"
              aria-label="<%= t("bible.reader.dismiss_toolbar") %>"
              class="h-7 rounded-full px-2 font-ui text-sm text-surface-50/70 transition-colors hover:bg-surface-700 hover:text-surface-50 dark:hover:bg-surface-700">
        &times;
      </button>
    <% end %>
  <% end %>

  <nav aria-label="<%= t("bible.reader.chapter_label") %>" class="flex items-center justify-between border-t border-surface-200 pt-6 font-ui text-sm dark:border-surface-800">
    <% if prev_chapter %>
      <%= link_to bible_chapter_path(translation: @translation.code.downcase,
                                     book: prev_chapter.book.osis_code.downcase,
                                     chapter: prev_chapter.number),
                  class: "inline-flex items-center gap-1 text-surface-600 transition-colors hover:text-accent-700 dark:text-surface-400 dark:hover:text-accent-400" do %>
        <span aria-hidden="true">&larr;</span>
        <%= t("bible.reader.prev_chapter") %>
      <% end %>
    <% else %>
      <span aria-hidden="true"></span>
    <% end %>

    <% if next_chapter %>
      <%= link_to bible_chapter_path(translation: @translation.code.downcase,
                                     book: next_chapter.book.osis_code.downcase,
                                     chapter: next_chapter.number),
                  class: "inline-flex items-center gap-1 text-surface-600 transition-colors hover:text-accent-700 dark:text-surface-400 dark:hover:text-accent-400" do %>
        <%= t("bible.reader.next_chapter") %>
        <span aria-hidden="true">&rarr;</span>
      <% end %>
    <% end %>
  </nav>
</article>
