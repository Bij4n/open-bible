<% content_for :title, t("admin.notes.title") %>

<article class="mx-auto max-w-3xl space-y-6">
  <header class="space-y-2 border-b border-surface-200 pb-6 dark:border-surface-800">
    <p class="font-ui text-xs font-medium uppercase tracking-wider text-surface-500 dark:text-surface-400">
      <%= t("admin.title") %>
    </p>
    <h1 class="font-mono text-xl text-surface-900 dark:text-surface-50 sm:text-2xl">
      <%= @note.highlights.map(&:osis_ref).join(", ") %>
    </h1>
    <p class="font-ui text-sm italic text-surface-600 dark:text-surface-400">
      by <%= @note.user.author_name %>
    </p>
  </header>

  <section class="rounded-2xl border border-surface-200 bg-surface-50 p-6 dark:border-surface-800 dark:bg-surface-900 sm:p-8">
    <div class="trix-content font-reading text-surface-900 dark:text-surface-100">
      <%= @note.body %>
    </div>
  </section>

  <section class="rounded-2xl border border-surface-200 bg-surface-50 p-6 dark:border-surface-800 dark:bg-surface-900 sm:p-8">
    <h2 class="font-ui text-xs font-semibold uppercase tracking-wider text-surface-500 dark:text-surface-400">
      <%= t("admin.notes.header_flags") %> (<%= @note.flags.unresolved.size %>)
    </h2>
    <ul class="mt-3 space-y-2 font-ui text-sm text-surface-700 dark:text-surface-300">
      <% @note.flags.unresolved.includes(:user).each do |flag| %>
        <li class="rounded-md border border-surface-200 bg-surface-100 px-3 py-2 dark:border-surface-800 dark:bg-surface-950/50">
          <strong class="text-surface-900 dark:text-surface-100"><%= flag.reason %></strong>
          <span class="text-surface-500 dark:text-surface-400">— <%= flag.user.author_name %></span>
          <% if flag.details.present? %><em class="ml-1"><%= flag.details %></em><% end %>
        </li>
      <% end %>
    </ul>
  </section>
</article>
