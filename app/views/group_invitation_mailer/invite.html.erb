<%# Inline-styled HTML email — most email clients (Gmail, iCloud,
    Outlook) strip class-based stylesheets, so the brand chrome lives
    in style="" attributes. Mirrors the static error page CSS
    vocabulary (#0F5C3F mint, paper bg, Instrument Serif italic em).
    Plaintext fallback in invite.text.erb. %>
<div style="background:#f7f8f5; padding:32px 16px; font-family:ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI','Helvetica Neue',Arial,sans-serif; color:#161e1a; line-height:1.5;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:560px; margin:0 auto;">
    <tr>
      <td>
        <p style="margin:0 0 32px 0; font-weight:600; font-size:17px; letter-spacing:-0.01em; color:#161e1a;">
          <span style="display:inline-block; width:14px; height:14px; border-radius:50%; background:#0F5C3F; margin-right:10px; vertical-align:-2px;"></span>
          <%= t("app.name") %>
        </p>

        <p style="margin:0 0 8px 0; font-family:ui-monospace,'JetBrains Mono',SFMono-Regular,Menlo,Consolas,monospace; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.1em; color:#677470;">
          <%= t("group_invitation_mailer.invite.eyebrow") %>
        </p>
        <h1 style="margin:0 0 24px 0; font-size:32px; font-weight:600; line-height:1.1; letter-spacing:-0.025em; color:#161e1a;">
          <%= t("group_invitation_mailer.invite.heading_html",
                inviter: @inviter.author_name, group_name: @group.name).html_safe %>
        </h1>

        <p style="margin:0 0 16px 0; font-family:'Instrument Serif',ui-serif,Georgia,serif; font-size:18px; line-height:1.6; color:#4a5450;">
          <%= t("group_invitation_mailer.invite.body_1", inviter: @inviter.author_name) %>
        </p>

        <% if @group.description.present? %>
          <p style="margin:0 0 16px 0; padding:14px 16px; background:#ecefe7; border-radius:8px; font-family:'Instrument Serif',ui-serif,Georgia,serif; font-style:italic; font-size:16px; line-height:1.5; color:#4a5450;">
            <%= @group.description %>
          </p>
        <% end %>

        <p style="margin:24px 0;">
          <a href="<%= @accept_url %>"
             style="display:inline-block; background:#161e1a; color:#f7f8f5; padding:14px 28px; border-radius:9999px; font-weight:500; font-size:15px; text-decoration:none;">
            <%= t("group_invitation_mailer.invite.cta") %>
          </a>
        </p>

        <p style="margin:24px 0 0 0; font-size:13px; color:#677470;">
          <%= t("group_invitation_mailer.invite.expires_in", days: @expires_in_days) %>
        </p>

        <p style="margin:32px 0 0 0; padding-top:20px; border-top:1px solid #dde2d8; font-size:12px; color:#677470; line-height:1.5;">
          <%= t("group_invitation_mailer.invite.footer_html").html_safe %>
        </p>
      </td>
    </tr>
  </table>
</div>
