<% content_for :title, t("admin.notes.title") %>

<article class="mx-auto max-w-5xl space-y-6">
  <header class="space-y-1 border-b border-walnut-900/15 pb-4 dark:border-gilt-500/30">
    <p class="text-sm uppercase tracking-[0.3em] text-walnut-700/70 dark:text-amber-200/60">
      <%= t("admin.title") %>
    </p>
    <h1 class="font-display text-3xl uppercase tracking-[0.1em] text-walnut-900 dark:text-amber-200">
      <%= t("admin.notes.title") %>
    </h1>
  </header>

  <nav class="flex items-center gap-4 text-sm font-display uppercase tracking-wider">
    <% [ %w[all All], %w[flagged Flagged], %w[featured Featured], %w[hidden Hidden] ].each do |filter, _| %>
      <%= link_to t("admin.filters.#{filter}"),
                  admin_notes_path(filter: (filter == "all" ? nil : filter)),
                  class: "#{"underline underline-offset-4" if @filter == filter || (filter == "all" && @filter.blank?)} hover:text-rubric-500 dark:hover:text-gilt-400" %>
    <% end %>
    <span aria-hidden="true" class="text-walnut-900/30 dark:text-amber-200/30">·</span>
    <%= link_to t("admin.nav.flags"), admin_flags_path, class: "hover:text-rubric-500 dark:hover:text-gilt-400" %>
  </nav>

  <% if @notes.any? %>
    <table class="w-full table-auto border-collapse text-sm">
      <thead class="border-b border-walnut-900/20 text-left font-display uppercase tracking-wider text-walnut-700/80 dark:border-gilt-500/30 dark:text-amber-200/80">
        <tr>
          <th class="py-2 pr-3"><%= t("admin.notes.header_author") %></th>
          <th class="py-2 pr-3"><%= t("admin.notes.header_preview") %></th>
          <th class="py-2 pr-3 text-center"><%= t("admin.notes.header_upvotes") %></th>
          <th class="py-2 pr-3 text-center"><%= t("admin.notes.header_flags") %></th>
          <th class="py-2 pr-3"><%= t("admin.notes.header_status") %></th>
          <th class="py-2 pr-3 text-right"><%= t("admin.notes.header_actions") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-walnut-900/10 font-serif dark:divide-gilt-500/20">
        <% @notes.each do |note| %>
          <tr class="<%= "bg-rubric-500/5" if note.flags.unresolved.any? %>">
            <td class="py-2 pr-3"><%= note.user.author_name %></td>
            <td class="py-2 pr-3 max-w-md truncate"><%= truncate(note.body.to_plain_text, length: 100) %></td>
            <td class="py-2 pr-3 text-center"><%= note.upvote_count %></td>
            <td class="py-2 pr-3 text-center"><%= note.flags.unresolved.size %></td>
            <td class="py-2 pr-3 space-x-1 text-xs">
              <% if note.featured? %>
                <span class="rounded bg-gilt-500/20 px-2 py-0.5 uppercase tracking-wider text-gilt-500"><%= t("public_bible.featured") %></span>
              <% end %>
              <% if note.hidden? %>
                <span class="rounded bg-rubric-500/20 px-2 py-0.5 uppercase tracking-wider text-rubric-600"><%= t("public_bible.hidden") %></span>
              <% end %>
            </td>
            <td class="py-2 pr-0 text-right space-x-1">
              <% if note.featured? %>
                <%= button_to t("admin.notes.unfeature"), unfeature_admin_note_path(note), method: :patch, form_class: "inline",
                              class: "rounded border border-walnut-900/25 px-2 py-0.5 text-xs hover:bg-walnut-900 hover:text-parchment-100 dark:border-gilt-500/40" %>
              <% else %>
                <%= button_to t("admin.notes.feature"), feature_admin_note_path(note), method: :patch, form_class: "inline",
                              class: "rounded border border-walnut-900/25 px-2 py-0.5 text-xs hover:bg-walnut-900 hover:text-parchment-100 dark:border-gilt-500/40" %>
              <% end %>
              <% if note.hidden? %>
                <%= button_to t("admin.notes.unhide"), unhide_admin_note_path(note), method: :patch, form_class: "inline",
                              class: "rounded border border-walnut-900/25 px-2 py-0.5 text-xs hover:bg-walnut-900 hover:text-parchment-100 dark:border-gilt-500/40" %>
              <% else %>
                <%= button_to t("admin.notes.hide"), hide_admin_note_path(note), method: :patch, form_class: "inline",
                              data: { turbo_confirm: t("admin.notes.hide") + "?" },
                              class: "rounded border border-rubric-500/40 px-2 py-0.5 text-xs text-rubric-600 hover:bg-rubric-500 hover:text-parchment-100" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="font-serif italic text-walnut-700 dark:text-amber-300"><%= t("admin.notes.empty") %></p>
  <% end %>
</article>
