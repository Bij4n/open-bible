<% content_for :title, t("admin.flags.title") %>

<article class="mx-auto max-w-5xl space-y-6">
  <header class="space-y-1 border-b border-walnut-900/15 pb-4 dark:border-gilt-500/30">
    <p class="text-sm uppercase tracking-[0.3em] text-walnut-700/70 dark:text-amber-200/60">
      <%= t("admin.title") %>
    </p>
    <h1 class="font-display text-3xl uppercase tracking-[0.1em] text-walnut-900 dark:text-amber-200">
      <%= t("admin.flags.title") %>
    </h1>
  </header>

  <nav class="flex items-center gap-4 text-sm font-display uppercase tracking-wider">
    <%= link_to t("admin.nav.notes"), admin_notes_path, class: "hover:text-rubric-500 dark:hover:text-gilt-400" %>
  </nav>

  <% if @flags.any? %>
    <table class="w-full table-auto border-collapse text-sm">
      <thead class="border-b border-walnut-900/20 text-left font-display uppercase tracking-wider text-walnut-700/80 dark:border-gilt-500/30 dark:text-amber-200/80">
        <tr>
          <th class="py-2 pr-3"><%= t("admin.flags.header_reporter") %></th>
          <th class="py-2 pr-3"><%= t("admin.flags.header_target") %></th>
          <th class="py-2 pr-3"><%= t("admin.flags.header_reason") %></th>
          <th class="py-2 pr-3"><%= t("admin.flags.header_details") %></th>
          <th class="py-2 pr-3"><%= t("admin.flags.header_created") %></th>
          <th class="py-2 pr-3 text-right"><%= t("admin.notes.header_actions") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-walnut-900/10 font-serif dark:divide-gilt-500/20">
        <% @flags.each do |flag| %>
          <tr>
            <td class="py-2 pr-3"><%= flag.user.author_name %></td>
            <td class="py-2 pr-3 text-xs"><%= flag.flaggable_type %> #<%= flag.flaggable_id %></td>
            <td class="py-2 pr-3"><%= flag.reason %></td>
            <td class="py-2 pr-3 max-w-md truncate"><%= flag.details %></td>
            <td class="py-2 pr-3 text-xs"><%= l(flag.created_at, format: :short) %></td>
            <td class="py-2 pr-0 text-right">
              <%= button_to t("admin.flags.resolve"),
                            resolve_admin_flag_path(flag),
                            method: :patch,
                            form_class: "inline",
                            class: "rounded border border-walnut-900/25 px-2 py-0.5 text-xs hover:bg-walnut-900 hover:text-parchment-100 dark:border-gilt-500/40" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="font-serif italic text-walnut-700 dark:text-amber-300"><%= t("admin.flags.empty") %></p>
  <% end %>
</article>
