<!DOCTYPE html>
<%# resolved_theme is "light"/"dark" only when the signed-in user pinned
    it; otherwise the Stimulus controller decides on connect and we leave
    data-theme unset. That avoids a flash of the wrong palette for users
    who've saved a preference. %>
<html lang="<%= I18n.locale %>"<%= " data-theme=\"#{resolved_theme}\"".html_safe if resolved_theme %> data-controller="theme">
  <head>
    <title><%= content_for(:title) || t("app.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t("app.name") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:rounded focus:bg-walnut-900 focus:px-3 focus:py-1 focus:text-parchment-100">
      <%= t("layout.skip_to_content") %>
    </a>

    <header class="border-b border-walnut-900/20 dark:border-gilt-500/30">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-5">
        <%= link_to root_path, class: "font-display text-2xl font-semibold uppercase tracking-[0.18em] text-walnut-900 dark:text-amber-200" do %>
          <%= t("app.name") %>
        <% end %>

        <nav class="flex items-center gap-5 text-sm" aria-label="<%= t("layout.language_switcher") %>">
          <%= render "shared/language_switcher" %>

          <button type="button"
                  data-action="theme#toggle"
                  class="rounded border border-walnut-900/30 px-3 py-1 text-xs uppercase tracking-wider hover:bg-walnut-900 hover:text-parchment-100 dark:border-gilt-500/40 dark:hover:bg-amber-200 dark:hover:text-walnut-900">
            <span data-theme-target="label"
                  data-label-light="<%= t("layout.theme_toggle_light") %>"
                  data-label-dark="<%= t("layout.theme_toggle_dark") %>">
              <%= t("layout.theme_toggle") %>
            </span>
          </button>

          <% if user_signed_in? %>
            <% if current_user.admin? %>
              <%= link_to t("admin.title"), admin_notes_path, class: "hover:text-rubric-500 dark:hover:text-gilt-400" %>
            <% end %>
            <%= link_to t("auth.settings"), settings_path, class: "hover:text-rubric-500 dark:hover:text-gilt-400" %>
            <%= button_to t("auth.sign_out"), destroy_user_session_path, method: :delete, class: "hover:text-rubric-500 dark:hover:text-gilt-400" %>
          <% else %>
            <%= link_to t("auth.sign_in"), new_user_session_path, class: "hover:text-rubric-500 dark:hover:text-gilt-400" %>
            <%= link_to t("auth.sign_up"), new_user_registration_path, class: "hover:text-rubric-500 dark:hover:text-gilt-400" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main id="main" class="mx-auto max-w-5xl px-6 py-12">
      <%= render "shared/flashes" %>
      <%= yield %>
    </main>

    <aside id="note-panel-container"
           class="fixed inset-y-0 right-0 w-full max-w-full translate-x-full transform bg-parchment-100 shadow-xl transition-transform duration-150 ease-out sm:max-w-md dark:bg-walnut-900"
           aria-label="Note editor">
      <div class="h-full overflow-y-auto p-5">
        <%= turbo_frame_tag "note_panel" %>
      </div>
    </aside>
  </body>
</html>
