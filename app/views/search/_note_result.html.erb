<li class="rounded border border-walnut-900/15 bg-parchment-50 p-3 dark:border-gilt-500/30 dark:bg-walnut-800">
  <header class="flex items-start justify-between gap-3">
    <p class="text-xs uppercase tracking-[0.18em] text-walnut-700/70 dark:text-amber-200/60">
      <%= note.highlights.map(&:osis_ref).join(", ") %>
      <span class="ml-2 italic normal-case tracking-normal">
        <%= t("search.by_author", name: note.user.author_name) %>
      </span>
    </p>
    <% if note.upvote_count.positive? %>
      <span class="text-xs text-walnut-700 dark:text-amber-300">
        <%= t("search.upvotes", count: note.upvote_count) %>
      </span>
    <% end %>
  </header>
  <p class="mt-1 font-serif text-sm text-walnut-900 dark:text-amber-200">
    <%= highlight_terms(note.body.to_plain_text, query) %>
  </p>
</li>
