<% book_name = I18n.locale == :es ? @book.name_es : @book.name_en %>
<% prev_chapter = @chapter.previous %>
<% next_chapter = @chapter.next %>
<% debug_selection = Rails.env.development? || params[:debug] == "1" %>

<article class="relative mx-auto max-w-3xl space-y-8"
         data-controller="highlight"
         data-highlight-translation-code-value="<%= @translation.code %>"
         data-highlight-book-value="<%= @book.osis_code %>"
         data-highlight-chapter-value="<%= @chapter.number %>"
         data-highlight-debug-value="<%= debug_selection %>">
  <nav aria-label="<%= t("bible.reader.chapter_label") %>" class="flex items-center justify-between gap-4 text-sm uppercase tracking-wider">
    <% if prev_chapter %>
      <%= link_to t("bible.reader.prev_chapter"),
                  bible_chapter_path(translation: @translation.code.downcase,
                                     book: prev_chapter.book.osis_code.downcase,
                                     chapter: prev_chapter.number),
                  class: "text-walnut-700 hover:text-rubric-500 dark:text-amber-300 dark:hover:text-gilt-400" %>
    <% else %>
      <span aria-hidden="true"></span>
    <% end %>

    <select data-controller="chapter-picker"
            data-action="change->chapter-picker#navigate"
            aria-label="<%= t("bible.reader.chapter_label") %>"
            class="rounded border border-walnut-900/30 bg-transparent px-3 py-1 font-serif text-sm normal-case tracking-normal dark:border-gilt-500/40">
      <% @book.chapters.order(:number).each do |ch| %>
        <option value="<%= bible_chapter_path(translation: @translation.code.downcase, book: @book.osis_code.downcase, chapter: ch.number) %>"
                <%= "selected" if ch.id == @chapter.id %>>
          <%= t("bible.reader.chapter_label") %> <%= ch.number %>
        </option>
      <% end %>
    </select>

    <% if next_chapter %>
      <%= link_to t("bible.reader.next_chapter"),
                  bible_chapter_path(translation: @translation.code.downcase,
                                     book: next_chapter.book.osis_code.downcase,
                                     chapter: next_chapter.number),
                  class: "text-walnut-700 hover:text-rubric-500 dark:text-amber-300 dark:hover:text-gilt-400" %>
    <% else %>
      <span aria-hidden="true"></span>
    <% end %>
  </nav>

  <header class="space-y-2 border-b border-walnut-900/15 pb-6 dark:border-gilt-500/30">
    <div class="flex items-center justify-between gap-3">
      <p class="text-sm uppercase tracking-[0.3em] text-walnut-700/70 dark:text-amber-200/60">
        <%= @translation.name %>
      </p>
      <% translations = Translation.order(:name) %>
      <% if translations.size > 1 %>
        <select data-controller="translation-picker"
                data-action="change->translation-picker#navigate"
                aria-label="<%= t("bible.reader.translation_picker") %>"
                class="rounded border border-walnut-900/30 bg-transparent px-3 py-1 font-serif text-sm normal-case tracking-normal dark:border-gilt-500/40">
          <% translations.each do |t| %>
            <option value="<%= bible_chapter_path(translation: t.code.downcase, book: @book.osis_code.downcase, chapter: @chapter.number) %>"
                    <%= "selected" if t.id == @translation.id %>>
              <%= t.name %>
            </option>
          <% end %>
        </select>
      <% end %>
    </div>
    <h1 class="font-display text-5xl font-semibold uppercase tracking-[0.1em] text-walnut-900 dark:text-amber-200">
      <%= book_name %> <%= @chapter.number %>
    </h1>
  </header>

  <div class="chapter-body font-serif text-lg leading-loose text-walnut-900 dark:text-amber-200"
       data-highlight-target="chapter">
    <% @verses.each_with_index do |verse, i| %><%= render partial: "bible/reader/verse", locals: { verse: verse, highlights: @highlights || [] } %><%= " " unless i == @verses.size - 1 %><% end %>
  </div>

  <% if user_signed_in? %>
    <div data-highlight-target="toolbar"
         hidden
         class="absolute z-20 flex items-center gap-1 rounded border border-walnut-900/30 bg-parchment-50 p-1 shadow-md dark:border-gilt-500/40 dark:bg-walnut-800">
      <% Highlight::COLORS.each do |color| %>
        <button type="button"
                data-action="highlight#apply"
                data-color="<%= color %>"
                title="<%= color.capitalize %>"
                class="h-6 w-6 rounded-full border border-walnut-900/30 dark:border-gilt-500/40 highlight-swatch-<%= color %>">
          <span class="sr-only"><%= color.capitalize %></span>
        </button>
      <% end %>
      <button type="button"
              data-action="highlight#note"
              title="<%= t("notes.save", default: "Note") %>"
              class="h-6 rounded px-2 text-xs uppercase tracking-wider text-walnut-900 hover:bg-walnut-900 hover:text-parchment-100 dark:text-amber-200 dark:hover:bg-amber-200 dark:hover:text-walnut-900">
        &#9998;
      </button>
      <button type="button"
              data-action="highlight#remove"
              title="<%= t("bible.reader.remove_highlight", default: "Remove") %>"
              class="h-6 rounded px-2 text-xs uppercase tracking-wider text-walnut-900 hover:bg-walnut-900 hover:text-parchment-100 dark:text-amber-200 dark:hover:bg-amber-200 dark:hover:text-walnut-900">
        &times;
      </button>
    </div>
  <% end %>

  <nav aria-label="<%= t("bible.reader.chapter_label") %>" class="flex items-center justify-between border-t border-walnut-900/15 pt-6 text-sm uppercase tracking-wider dark:border-gilt-500/30">
    <% if prev_chapter %>
      <%= link_to t("bible.reader.prev_chapter"),
                  bible_chapter_path(translation: @translation.code.downcase,
                                     book: prev_chapter.book.osis_code.downcase,
                                     chapter: prev_chapter.number),
                  class: "text-walnut-700 hover:text-rubric-500 dark:text-amber-300 dark:hover:text-gilt-400" %>
    <% else %>
      <span aria-hidden="true"></span>
    <% end %>

    <% if next_chapter %>
      <%= link_to t("bible.reader.next_chapter"),
                  bible_chapter_path(translation: @translation.code.downcase,
                                     book: next_chapter.book.osis_code.downcase,
                                     chapter: next_chapter.number),
                  class: "text-walnut-700 hover:text-rubric-500 dark:text-amber-300 dark:hover:text-gilt-400" %>
    <% end %>
  </nav>
</article>
