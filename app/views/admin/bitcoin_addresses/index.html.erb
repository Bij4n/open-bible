<% content_for :title, t("admin.bitcoin_addresses.title") %>
<%
  primary_btn = "rounded-full bg-accent-700 px-5 py-2 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800 dark:bg-accent-400 dark:text-surface-950 dark:hover:bg-accent-300"
  nav_link    = "transition-colors hover:text-accent-700 dark:hover:text-accent-400"
%>

<article class="mx-auto max-w-5xl space-y-6">
  <header class="space-y-2 border-b border-surface-200 pb-6 dark:border-surface-800">
    <p class="font-ui text-xs font-medium uppercase tracking-wider text-surface-500 dark:text-surface-400">
      <%= t("admin.title") %>
    </p>
    <h1 class="font-ui text-3xl font-semibold tracking-tight text-surface-900 dark:text-surface-50 sm:text-4xl">
      <%= t("admin.bitcoin_addresses.title") %>
    </h1>
  </header>

  <nav class="flex items-center gap-4 font-ui text-sm text-surface-700 dark:text-surface-300">
    <%= link_to t("admin.nav.notes"), admin_notes_path, class: nav_link %>
    <%= link_to t("admin.nav.flags"), admin_flags_path, class: nav_link %>
  </nav>

  <div>
    <%= link_to t("admin.bitcoin_addresses.new"), new_admin_bitcoin_address_path, class: primary_btn %>
  </div>

  <% if @addresses.any? %>
    <table class="w-full table-auto border-collapse font-ui text-sm">
      <thead class="border-b border-surface-200 text-left text-xs font-semibold uppercase tracking-wider text-surface-500 dark:border-surface-800 dark:text-surface-400">
        <tr>
          <th class="py-2 pr-3"><%= t("admin.bitcoin_addresses.header_address") %></th>
          <th class="py-2 pr-3"><%= t("admin.bitcoin_addresses.header_status") %></th>
          <th class="py-2 pr-3"><%= t("admin.bitcoin_addresses.header_notes") %></th>
          <th class="py-2 pr-3"><%= t("admin.bitcoin_addresses.header_created") %></th>
          <th class="py-2 pr-3"><%= t("admin.bitcoin_addresses.header_archived") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-surface-200 text-surface-900 dark:divide-surface-800 dark:text-surface-100">
        <% @addresses.each do |address| %>
          <tr class="<%= "bg-accent-700/5 dark:bg-accent-400/5" if address.active %>">
            <td class="py-2 pr-3 font-mono text-xs break-all"><%= address.address %></td>
            <td class="py-2 pr-3 text-xs">
              <% if address.active %>
                <span class="rounded-full bg-accent-700/10 px-2.5 py-0.5 font-medium tracking-wide text-accent-700 dark:bg-accent-400/10 dark:text-accent-400">
                  <%= t("admin.bitcoin_addresses.active_badge") %>
                </span>
              <% else %>
                <span class="text-surface-500 dark:text-surface-400">
                  <%= t("admin.bitcoin_addresses.archived_badge") %>
                </span>
              <% end %>
            </td>
            <td class="py-2 pr-3 max-w-xs text-xs text-surface-600 dark:text-surface-400"><%= address.notes %></td>
            <td class="py-2 pr-3 text-xs text-surface-600 dark:text-surface-400"><%= l(address.created_at, format: :short) %></td>
            <td class="py-2 pr-3 text-xs text-surface-600 dark:text-surface-400">
              <%= l(address.archived_at, format: :short) if address.archived_at %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="font-ui text-sm text-surface-600 dark:text-surface-400">
      <%= t("admin.bitcoin_addresses.empty") %>
    </p>
  <% end %>
</article>
