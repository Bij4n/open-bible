<%= turbo_frame_tag dom_id(@note) do %>
  <article class="rounded-2xl border border-surface-200 bg-surface-50 p-6 dark:border-surface-800 dark:bg-surface-900 sm:p-8">
    <header class="mb-3 flex items-start justify-between gap-2">
      <%# osis_ref eyebrow — Inter uppercase per design v3 (mono is
          retired from product UI). %>
      <p class="font-ui text-xs uppercase tracking-widest text-surface-500 dark:text-surface-400">
        <%= @note.highlights.map(&:osis_ref).join(", ") %>
      </p>
    </header>

    <div class="trix-content font-reading text-surface-900 dark:text-surface-100">
      <%= @note.body %>
    </div>

    <%= render partial: "comments/thread", locals: { note: @note } %>
  </article>
<% end %>
