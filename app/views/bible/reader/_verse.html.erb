<%# Shared verse span used by both the private reader and the group bible
    reader. The dom_id ("verse_<id>") is stable across renders so real-time
    broadcasts can target it via turbo_stream.replace.

    cross_translation_highlights: hash of verse_number => other translation
    code for verses the current user has annotated in another translation.
    Rendered as a linked bridge badge so a click jumps to the same verse
    in the other translation. %>
<% bridge_code = local_assigns[:cross_translation_highlights]&.dig(verse.number) %>
<% chapter_opener = local_assigns[:chapter_opener] %>
<span class="verse"
      id="<%= dom_id(verse) %>"
      data-verse-id="<%= verse.id %>"
      data-osis-ref="<%= verse.osis_ref %>"
      data-verse-text="<%= verse.body_text %>"><sup class="verse-number" data-ignore-selection><%= verse.number %></sup><% if bridge_code %><%= link_to bible_chapter_path(translation: bridge_code.downcase, book: verse.chapter.book.osis_code.downcase, chapter: verse.chapter.number), class: "cross-translation-badge ml-1 text-xs text-walnut-700/60 hover:text-rubric-500 dark:text-amber-200/60 dark:hover:text-gilt-400", data: { ignore_selection: true, turbo: false }, title: t("bible.reader.cross_translation_badge_title", translation: bridge_code) do %><sup data-ignore-selection>&#9775;</sup><% end %><% end %><% if chapter_opener %><span class="chapter-opening"><%= render_verse_with_highlights(verse, Array(highlights)) %></span><% else %><%= render_verse_with_highlights(verse, Array(highlights)) %><% end %></span>
