<%= form_with model: group, class: "space-y-5" do |f| %>
  <% if group.errors.any? %>
    <div role="alert" class="rounded border border-rubric-500/50 bg-rubric-500/10 px-4 py-3 font-serif text-sm text-rubric-600 dark:text-amber-100">
      <ul class="list-inside list-disc space-y-1">
        <% group.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "mb-1 block font-serif text-sm font-medium uppercase tracking-wider text-walnut-900/80 dark:text-amber-200/80" %>
    <%= f.text_field :name, required: true, maxlength: 100,
        class: "w-full rounded border border-walnut-900/25 bg-parchment-50 px-3 py-2 font-serif text-walnut-900 focus:border-walnut-900 focus:outline-none focus:ring-1 focus:ring-walnut-900 dark:border-gilt-500/40 dark:bg-walnut-900 dark:text-amber-200" %>
  </div>

  <div>
    <%= f.label :description, class: "mb-1 block font-serif text-sm font-medium uppercase tracking-wider text-walnut-900/80 dark:text-amber-200/80" %>
    <%= f.text_area :description, rows: 3, maxlength: 500,
        class: "w-full rounded border border-walnut-900/25 bg-parchment-50 px-3 py-2 font-serif text-walnut-900 focus:border-walnut-900 focus:outline-none focus:ring-1 focus:ring-walnut-900 dark:border-gilt-500/40 dark:bg-walnut-900 dark:text-amber-200" %>
  </div>

  <fieldset class="space-y-2 font-serif text-sm">
    <legend class="mb-1 block font-serif text-sm font-medium uppercase tracking-wider text-walnut-900/80 dark:text-amber-200/80">
      <%= Group.human_attribute_name(:privacy) %>
    </legend>
    <% Group::PRIVACIES.keys.each do |key| %>
      <label class="flex items-center gap-2">
        <%= f.radio_button :privacy, key %>
        <%= t("groups.privacy.#{key}") %>
      </label>
    <% end %>
  </fieldset>

  <div class="flex items-center justify-end gap-3">
    <%= link_to t("groups.cancel"), groups_path, class: "font-serif text-sm text-walnut-700 hover:text-rubric-500 dark:text-amber-300" %>
    <%= f.submit class: "rounded bg-walnut-900 px-4 py-2 font-display text-sm font-medium uppercase tracking-wider text-parchment-100 hover:bg-walnut-800 dark:bg-amber-200 dark:text-walnut-900 dark:hover:bg-amber-100" %>
  </div>
<% end %>
