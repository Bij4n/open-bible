<% heading = t(".sign_up") %>
<%
  label_classes  = "mb-1.5 block font-ui text-sm font-medium text-surface-900 dark:text-surface-100"
  input_classes  = "w-full rounded-md border border-surface-300 bg-surface-50 px-3 py-2 font-ui text-sm text-surface-900 transition-colors placeholder:text-surface-500 focus:border-accent-700 focus:outline-none focus:ring-2 focus:ring-accent-700/20 dark:border-surface-700 dark:bg-surface-900 dark:text-surface-100 dark:focus:border-accent-400 dark:focus:ring-accent-400/20"
  hint_classes   = "mb-1.5 font-ui text-xs text-surface-600 dark:text-surface-400"
  submit_classes = "w-full rounded-md bg-accent-700 px-4 py-2.5 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800 dark:bg-accent-400 dark:text-surface-950 dark:hover:bg-accent-300"
%>

<%= render "devise/shared/auth_shell", heading: heading do %>
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: label_classes %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: input_classes %>
    </div>

    <div>
      <%= f.label :password, class: label_classes %>
      <% if @minimum_password_length %>
        <p class="<%= hint_classes %>">
          <%= t("devise.shared.minimum_password_length", count: @minimum_password_length) %>
        </p>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password", class: input_classes %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: label_classes %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: input_classes %>
    </div>

    <%= f.submit heading, class: submit_classes %>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
