<%# Broadcast renders call this partial without a request context, so
    current_user raises Devise::MissingWarden there. Fall back safely —
    the partial renders without author controls in broadcasts, and the
    author sees them on the next full page render. %>
<% viewer = local_assigns.fetch(:viewer) { current_user rescue nil } %>
<% indent = [ comment.depth, Comment::MAX_DEPTH ].min * 20 %>
<article id="<%= dom_id(comment) %>"
         data-controller="comment"
         data-depth="<%= comment.depth %>"
         class="comment mt-2"
         style="margin-left: <%= indent %>px;">
  <header class="flex items-center justify-between gap-2 font-ui text-xs text-surface-600 dark:text-surface-400">
    <span>
      <strong class="font-ui font-semibold text-surface-900 dark:text-surface-100">
        <%= comment.user.author_name %>
      </strong>
      <span class="ml-2 italic">
        <%= t("comments.timestamp", ago: time_ago_in_words(comment.created_at)) %>
      </span>
    </span>
  </header>

  <div class="mt-1 whitespace-pre-wrap font-reading text-sm text-surface-900 dark:text-surface-100">
    <%= comment.body %>
  </div>

  <footer class="mt-1 flex items-center gap-3 font-ui text-xs text-surface-600 dark:text-surface-400">
    <% if comment.depth < Comment::MAX_DEPTH %>
      <button type="button"
              data-action="comment#toggleReply"
              class="transition-colors hover:text-accent-700 dark:hover:text-accent-400">
        <%= t("comments.reply") %>
      </button>
    <% end %>

    <% if viewer && comment.user_id == viewer.id %>
      <%= button_to t("comments.delete"),
                    comment_path(comment),
                    method: :delete,
                    form_class: "inline",
                    data: { turbo_confirm: t("comments.confirm_delete") },
                    class: "transition-colors hover:text-red-700 dark:hover:text-red-400" %>
    <% end %>
  </footer>

  <div data-comment-target="replyForm" class="mt-2 hidden">
    <%= render partial: "comments/form", locals: { note: comment.note, parent: comment } %>
  </div>
</article>
